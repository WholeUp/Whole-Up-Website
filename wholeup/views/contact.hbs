              <select name="service" class="w-full bg-white border border-black/10 rounded-xl px-5 py-4 text-dark focus:outline-none focus:border-primary transition font-medium appearance-none">
                <option value="">Select a service...</option>
                <option>SEO & Organic Growth</option>
                <option>Paid Advertising (Google / Meta)</option>
                <option>Social Media Marketing</option>
                <option>Web Design & Development</option>
                <option>YouTube Management</option>
                <option>Email Marketing</option>
                <option>Full-Service Package</option>
                <option>Not sure — need advice</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-bold uppercase tracking-widest text-dark/50 mb-2">Tell Us About Your Business *</label>
              <textarea name="message" required rows="5" placeholder="What does your business do? What are your current marketing challenges? What results are you looking for?" class="w-full bg-white border border-black/10 rounded-xl px-5 py-4 text-dark focus:outline-none focus:border-primary transition font-medium resize-none"></textarea>
