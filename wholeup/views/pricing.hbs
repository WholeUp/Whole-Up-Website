<!-- HERO -->
<section class="page-hero bg-cream px-6 border-b border-black/5">
  <div class="max-w-7xl mx-auto text-center gs-reveal">
    <p class="text-xs font-bold tracking-[0.3em] uppercase text-primary mb-4">Transparent Pricing</p>
    <h1 class="text-5xl md:text-7xl font-black uppercase tracking-widest text-dark mb-6">Simple, Honest <span class="text-primary">Pricing.</span></h1>
    <p class="text-dark/60 font-medium text-xl max-w-3xl mx-auto">No hidden fees. No lock-in contracts. Pick the plan that fits your stage of growth — and upgrade any time.</p>
  </div>
</section>

<!-- PRICING CARDS -->
<section class="py-24 bg-white px-6">
  <div class="max-w-6xl mx-auto">
    
    <!-- Billing Cycle Toggle Switch -->
    <div class="flex justify-center items-center gap-4 mb-16 gs-reveal">
      <span class="text-sm font-bold uppercase tracking-widest text-dark/70" id="label-monthly">Monthly</span>
      <button onclick="toggleBilling()" id="billing-switch" class="w-14 h-8 bg-black/10 hover:bg-black/15 rounded-full p-1 transition-colors duration-300 focus:outline-none relative cursor-pointer" aria-label="Toggle Billing Plan">
        <div id="switch-dot" class="w-6 h-6 bg-primary rounded-full transition-transform duration-300 shadow-md transform translate-x-0"></div>
      </button>
      <span class="text-sm font-bold uppercase tracking-widest text-dark/45 flex items-center gap-2" id="label-yearly">
        Yearly <span class="bg-primary text-white text-[9px] font-black px-2 py-0.5 rounded-full uppercase tracking-wider">Save 20%</span>
      </span>
    </div>

    <div class="grid md:grid-cols-3 gap-8 items-stretch">
      {{#each pricing}}
      <div class="relative rounded-[32px] border {{#if popular}}border-primary shadow-2xl shadow-primary/20{{else}}border-black/8 shadow-lg{{/if}} overflow-hidden gs-reveal flex flex-col" data-tilt data-tilt-max="3">
        {{#if popular}}
        <div class="bg-primary text-white text-[10px] font-black uppercase tracking-[0.3em] text-center py-3">⭐ Most Popular</div>
        {{/if}}
        <div class="p-10 flex flex-col flex-1 {{#if popular}}bg-dark text-white{{else}}bg-cream{{/if}}">
          <div class="mb-8">
            <h3 class="text-2xl font-black uppercase tracking-widest mb-2 {{#if popular}}text-white{{else}}text-dark{{/if}}">{{name}}</h3>
            <p class="text-sm font-medium {{#if popular}}text-white/60{{else}}text-dark/60{{/if}} mb-6">{{tagline}}</p>
            <div class="flex items-end gap-2 mb-1">
              <span class="text-5xl font-black {{#if popular}}text-white{{else}}text-dark{{/if}} price-amount" 
                data-monthly="{{price}}" 
                data-yearly="{{#if (eq name 'Starter')}}8,000{{/if}}{{#if (eq name 'Growth')}}17,600{{/if}}{{#if (eq name 'Premium')}}36,000{{/if}}">
                ₹{{price}}
              </span>
              <span class="text-sm font-bold {{#if popular}}text-white/50{{else}}text-dark/50{{/if}} mb-2">/month</span>
            </div>
            <p class="billing-note text-[9px] opacity-0 transition-opacity duration-300 font-bold uppercase tracking-widest text-primary leading-none h-3 select-none">Billed Annually</p>
            <p class="text-xs font-bold uppercase tracking-widest {{#if popular}}text-primary{{else}}text-dark/40{{/if}} mt-3">+ Ad spend passed through at cost</p>
          </div>
          <div class="space-y-3 mb-8 flex-1">
            {{#each features}}
            <div class="flex items-start gap-3 text-sm font-medium {{#if ../popular}}text-white/80{{else}}text-dark/80{{/if}}">
              <i class="fas fa-check-circle text-primary mt-0.5 flex-shrink-0"></i>{{this}}
            </div>
            {{/each}}
            {{#each notIncluded}}
            <div class="flex items-start gap-3 text-sm font-medium {{#if ../popular}}text-white/30{{else}}text-dark/30{{/if}}">
              <i class="fas fa-times-circle mt-0.5 flex-shrink-0"></i>{{this}}
            </div>
            {{/each}}
          </div>
          <a href="/contact" class="block text-center py-5 rounded-xl font-black uppercase tracking-widest text-sm transition magnetic-btn {{#if popular}}bg-primary text-white hover:bg-green-500{{else}}bg-dark text-white hover:bg-primary{{/if}}">
            {{cta}} →
          </a>
        </div>
      </div>
      {{/each}}
    </div>

    <!-- Custom note -->
    <div class="mt-12 bg-cream border border-black/5 rounded-3xl p-10 text-center gs-reveal">
      <h3 class="text-2xl font-black uppercase tracking-widest text-dark mb-4">Need a Custom Plan?</h3>
      <p class="text-dark/60 font-medium mb-8 max-w-2xl mx-auto">Every business is different. We're happy to build a custom package that fits your exact goals and budget.</p>
      <a href="/contact" class="inline-flex items-center gap-2 bg-primary text-white px-10 py-4 rounded-xl font-bold uppercase tracking-widest text-sm shadow-lg shadow-primary/30 hover:bg-green-600 transition magnetic-btn">
        Request Custom Quote <i class="fas fa-arrow-right"></i>
      </a>
    </div>
  </div>
</section>

<!-- FAQ SNIPPET -->
<section class="py-24 bg-cream px-6 border-t border-black/5">
  <div class="max-w-3xl mx-auto text-center gs-reveal">
    <h2 class="text-4xl font-black uppercase tracking-widest text-dark mb-4">Pricing Questions?</h2>
    <p class="text-dark/60 font-medium mb-8">We've answered the most common ones in our FAQ.</p>
    <a href="/faq" class="inline-flex items-center gap-2 border-2 border-dark text-dark px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-sm hover:bg-dark hover:text-white transition magnetic-btn">
      View FAQ <i class="fas fa-arrow-right"></i>
    </a>
  </div>
</section>

<script>
  let yearlyBilling = false;

  function toggleBilling() {
    yearlyBilling = !yearlyBilling;
    
    // Animate Switch Toggle
    const dot = document.getElementById('switch-dot');
    const bg = document.getElementById('billing-switch');
    const labelMonthly = document.getElementById('label-monthly');
    const labelYearly = document.getElementById('label-yearly');

    if (yearlyBilling) {
      dot.style.transform = 'translateX(24px)';
      bg.classList.replace('bg-black/10', 'bg-primary/20');
      labelMonthly.classList.replace('text-dark/70', 'text-dark/45');
      labelYearly.classList.replace('text-dark/45', 'text-dark/70');
    } else {
      dot.style.transform = 'translateX(0px)';
      bg.classList.replace('bg-primary/20', 'bg-black/10');
      labelMonthly.classList.replace('text-dark/45', 'text-dark/70');
      labelYearly.classList.replace('text-dark/70', 'text-dark/45');
    }

    // Update prices with smooth fade effect
    const priceElements = document.querySelectorAll('.price-amount');
    const notes = document.querySelectorAll('.billing-note');

    priceElements.forEach((el, index) => {
      const monthly = el.dataset.monthly;
      const yearly = el.dataset.yearly;
      const targetVal = yearlyBilling ? yearly : monthly;

      // Simple smooth text transition
      if (typeof gsap !== 'undefined') {
        gsap.to(el, {
          opacity: 0,
          y: -5,
          duration: 0.15,
          onComplete: () => {
            el.innerText = '₹' + targetVal;
            gsap.to(el, { opacity: 1, y: 0, duration: 0.2 });
          }
        });
      } else {
        el.innerText = '₹' + targetVal;
      }

      // Show/Hide Billed Annually note
      if (yearlyBilling) {
        notes[index].classList.replace('opacity-0', 'opacity-100');
      } else {
        notes[index].classList.replace('opacity-100', 'opacity-0');
      }
    });
  }
</script>
