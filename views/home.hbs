        <p class="text-white/50 text-xs font-medium leading-relaxed max-w-xs mx-auto">Our team launches campaigns, content, and optimizations with precision timing.</p>
      </div>
      
      <!-- Step 4 -->
      <div class="text-center relative group process-step-card">
        <div class="w-16 h-16 rounded-2xl bg-primary/10 border border-primary/30 flex items-center justify-center text-primary text-2xl mx-auto mb-6 transition-all duration-500 group-hover:scale-110 group-hover:border-primary group-hover:bg-primary/20 process-icon"><i class="fas fa-chart-line"></i></div>
