          <div class="w-10 h-10 rounded-full {{color}} text-white flex items-center justify-center text-xs font-black flex-shrink-0">{{initials}}</div>
          <div>
            <h4 class="font-black text-dark text-sm leading-tight">{{name}}</h4>
            <p class="text-[10px] text-primary font-bold tracking-widest uppercase mt-0.5">{{company}}</p>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</section>

<!-- ══ BLOG PREVIEW ══════════════════════════════════════════════════════ -->
<section class="py-32 bg-cream px-6 border-t border-black/5">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 gs-reveal">
      <div>
        <p class="text-xs font-bold tracking-[0.3em] uppercase text-primary mb-4">Latest Insights</p>
        <h2 class="text-5xl font-black uppercase tracking-widest text-dark">From the <span class="text-primary">Blog.</span></h2>
      </div>
      <a href="/blog" class="mt-6 md:mt-0 border-2 border-dark text-dark px-6 py-3 rounded-xl font-bold text-sm uppercase tracking-widest hover:bg-dark hover:text-white transition magnetic-btn">
        All Articles →
      </a>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {{#each featuredPosts}}
      <a href="/blog/{{slug}}" class="group bg-white rounded-[24px] overflow-hidden border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 gs-reveal flex flex-col">
        <div class="h-36 flex items-center justify-center relative overflow-hidden" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7)">
          <div class="absolute inset-0 opacity-25" style="background-image:radial-gradient(#16A34A22 1px,transparent 1px);background-size:18px 18px;"></div>
          <div class="text-center z-10">
            <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center mx-auto mb-2">
              <i class="fas fa-pen-nib text-lg text-primary"></i>
            </div>
          </div>
          <div class="absolute top-3 right-3 text-white text-[9px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full" style="background:{{categoryColor}}">{{category}}</div>
        </div>
        <div class="p-5 flex flex-col flex-1">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[10px] text-dark/40 font-medium">{{date}}</span>
            <span class="w-1 h-1 rounded-full bg-dark/20"></span>
            <span class="text-[10px] text-dark/40 font-medium">{{readTime}}</span>
          </div>
          <h3 class="text-sm font-black text-dark leading-snug mb-2 group-hover:text-primary transition flex-1">{{title}}</h3>
          <div class="flex items-center gap-1.5 text-primary text-xs font-semibold mt-3 border-t border-black/5 pt-3">
            Read Article <i class="fas fa-arrow-right text-[9px] group-hover:translate-x-1 transition-transform"></i>
          </div>
        </div>
      </a>
      {{/each}}
    </div>
  </div>
</section>

