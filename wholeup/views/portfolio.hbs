<!-- CUSTOM INLINE STYLES FOR THE LIGHT THEME PORTFOLIO PAGE -->
<style>
  /* Light Theme Variables */
  .portfolio-section {
    background-color: transparent;
    color: #0d0d0d;
  }
  
  .portfolio-card {
    --card-accent: var(--theme-color, #16A34A);
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.03);
    transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  
  .portfolio-card:hover {
    transform: translateY(-8px);
    border-color: color-mix(in srgb, var(--card-accent) 40%, transparent);
    box-shadow: 0 16px 32px color-mix(in srgb, var(--card-accent) 8%, transparent);
  }

  .portfolio-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 24px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(0,0,0,0.04) 0%, rgba(0,0,0,0.01) 50%, color-mix(in srgb, var(--card-accent) 40%, transparent) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  /* Soft Light Theme Blur Blobs */
  .blur-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(140px);
    opacity: 0.09;
    pointer-events: none;
    z-index: 0;
  }

  .blob-1 {
    width: 400px;
    height: 400px;
    background: #16A34A;
    top: 10%;
    left: 5%;
    animation: float1 20s infinite alternate;
  }

  .blob-2 {
    width: 500px;
    height: 500px;
    background: #06B6D4;
    bottom: 15%;
    right: 5%;
    animation: float2 25s infinite alternate;
  }

  .blob-3 {
    width: 350px;
    height: 350px;
    background: #7c3aed;
    top: 45%;
    left: 50%;
    transform: translateX(-50%);
    animation: float1 18s infinite alternate-reverse;
  }

  /* Light Theme Tab Selector */
  #filter-tabs {
    position: relative;
    border: 1px solid rgba(0, 0, 0, 0.05);
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 20px;
    padding: 6px;
    display: inline-flex;
    gap: 4px;
    z-index: 10;
  }

  .filter-tab {
    position: relative;
    padding: 10px 24px;
    border-radius: 14px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(13, 13, 13, 0.5);
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 2;
    transition: color 0.3s;
  }

  .filter-tab.active-tab {
    color: #ffffff;
  }

  #filter-pill {
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 6px;
    background: linear-gradient(135deg, #16A34A 0%, #15803D 100%);
    border-radius: 14px;
    z-index: 1;
    box-shadow: 0 4px 12px rgba(22, 163, 74, 0.2);
  }

  /* Mock Browser Custom Scroll */
  .mock-browser-scroll::-webkit-scrollbar {
    width: 4px;
  }
  .mock-browser-scroll::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.02);
  }
  .mock-browser-scroll::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.1);
    border-radius: 2px;
  }

  /* Custom Scrollbar for Modal Content */
  .modal-scroll::-webkit-scrollbar {
    width: 8px;
  }
  .modal-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .modal-scroll::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.15);
    border-radius: 99px;
    border: 2.5px solid #faf8f2;
  }
  .modal-scroll::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 0, 0, 0.3);
  }
</style>

<!-- IMMERSIVE LIGHT HERO -->
<section class="relative overflow-hidden pt-36 pb-20 px-6 border-b border-black/5">
  <!-- Soft blur blobs for ambient lighting -->
  <div class="blur-blob blob-1"></div>
  <div class="blur-blob blob-2"></div>
  <div class="blur-blob blob-3"></div>

  <!-- Space Background Grid Overlay (Uses existing light grid) -->
  <div class="absolute inset-0 bg-grid opacity-[0.4] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto text-center relative z-10 gs-reveal">
    <p class="text-xs font-bold tracking-[0.3em] uppercase text-primary mb-4 animate-pulse">Our Innovations & Case Studies</p>
    <h1 class="text-5xl md:text-8xl font-black uppercase tracking-wider text-dark mb-6">
      Our <span class="text-gradient">Impact.</span>
    </h1>
    <p class="text-dark/60 font-medium text-lg md:text-xl max-w-3xl mx-auto leading-relaxed">
      Browse our digital flagship products, interactive landing page architectures, and conversion-optimized performance reports.
    </p>
  </div>
</section>

<!-- MAIN PORTFOLIO CONTENT -->
<section class="py-24 relative px-6">
  <div class="max-w-7xl mx-auto relative z-10">
    
    <!-- Slider Navigation Tabs -->
    <div class="flex justify-center mb-16 gs-reveal">
      <div id="filter-tabs" class="p-1.5 flex flex-wrap justify-center relative">
        <div id="filter-pill"></div>
        <button onclick="filterPortfolio('all', this)" class="filter-tab active-tab">All Work</button>
        <button onclick="filterPortfolio('ai', this)" class="filter-tab">AI Automation</button>
        <button onclick="filterPortfolio('web', this)" class="filter-tab">Web Design</button>
        <button onclick="filterPortfolio('ads', this)" class="filter-tab">Paid Ads</button>
        <button onclick="filterPortfolio('seo', this)" class="filter-tab">SEO</button>
        <button onclick="filterPortfolio('social', this)" class="filter-tab">Social Media</button>
      </div>
    </div>

    <!-- Case Studies Cards Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" id="portfolio-grid">
      {{#each portfolio}}
      <div class="portfolio-card group relative overflow-hidden rounded-[24px] flex flex-col cursor-pointer gs-reveal" 
           data-category="{{category}}" 
           data-tilt data-tilt-max="4" 
           style="--theme-color: {{tagColor}};"
           onclick="openCaseModal({{id}})">
        
        <!-- Visual Header -->
        <div class="h-52 flex items-center justify-center relative overflow-hidden flex-shrink-0" style="background: linear-gradient(135deg, {{gradientFrom}} 0%, {{gradientTo}} 100%)">
          <!-- Ambient glowing mesh inside card header -->
          <div class="absolute inset-0 opacity-20 bg-cover bg-center" style="background-image: radial-gradient(circle at 30% 30%, {{tagColor}} 0%, transparent 60%);"></div>
          
          <div class="text-center z-10 p-6 flex flex-col items-center">
            <div class="w-16 h-16 bg-white/10 border border-white/10 backdrop-blur-md rounded-2xl shadow-xl flex items-center justify-center mb-4 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3 anim-float-1">
              <i class="{{icon}} text-2xl text-white" style="text-shadow: 0 0 10px {{tagColor}};"></i>
            </div>
            <p class="text-[9px] font-black tracking-[0.2em] uppercase text-white/60 bg-black/20 px-3 py-1 rounded-full border border-white/5">{{categoryLabel}}</p>
          </div>
          
          <!-- Category Indicator pill top right -->
          <div class="absolute top-4 right-4 text-white text-[9px] font-extrabold uppercase tracking-widest px-3 py-1.5 rounded-full backdrop-blur-md border border-white/10 bg-black/20 shadow-md">
            {{categoryLabel}}
          </div>
        </div>

        <!-- Card Body -->
        <div class="p-6 flex flex-col flex-1 relative z-10">
          <h3 class="text-xl font-black uppercase tracking-wide text-dark mb-3 group-hover:text-primary transition-colors duration-300">{{title}}</h3>
          <p class="text-dark/60 text-xs font-normal leading-relaxed mb-6 flex-1">{{description}}</p>

          <!-- Featured Metric Badges -->
          <div class="flex items-center gap-2 text-xs font-semibold mt-auto">
            <span class="px-4 py-2 rounded-xl text-white font-extrabold flex items-center gap-1.5 border border-white/5" style="background: {{tagBg}}; color: {{tagColor}}">
              <span class="w-2.5 h-2.5 rounded-full animate-ping" style="background: {{tagColor}}"></span>
              {{metric1}}
            </span>
            <span class="px-4 py-2 rounded-xl bg-dark/5 border border-black/5 text-dark/80 font-bold">{{metric2}}</span>
          </div>
        </div>

        <!-- Slide-in Action Hover Overlay (Stays high-contrast dark for details focus) -->
        <div class="absolute inset-0 bg-dark/95 flex flex-col justify-between p-6 opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 rounded-[24px] z-20 border border-white/10">
          <div class="text-center pt-8">
            <div class="w-12 h-12 rounded-full border border-white/15 bg-white/5 flex items-center justify-center mx-auto mb-4">
              <i class="fas fa-chart-bar text-lg" style="color: {{tagColor}}"></i>
            </div>
            <h4 class="font-black text-white text-base uppercase tracking-widest mb-3">Key Highlight</h4>
            <p class="text-white/70 text-xs leading-relaxed max-w-[240px] mx-auto mb-6">{{result}}</p>
          </div>
          
          <div class="mt-auto">
            <!-- Services deliver list -->
            <div class="flex flex-wrap gap-1.5 justify-center mb-6">
              {{#each services}}
              <span class="bg-white/5 border border-white/5 text-white/60 text-[8px] font-bold uppercase tracking-wider px-2 py-1 rounded">{{this}}</span>
              {{/each}}
            </div>
            <!-- Click Call To Action -->
            <div class="w-full text-center py-3.5 rounded-xl text-white font-bold text-xs uppercase tracking-widest border border-white/15 bg-white/5 hover:bg-primary hover:border-primary transition-all duration-300">
              Launch Case Study Details <i class="fas fa-external-link-alt ml-1"></i>
            </div>
          </div>
        </div>

      </div>
      {{/each}}
    </div>

  </div>
</section>

<div id="case-modal" class="fixed inset-0 z-[99999] bg-black/60 backdrop-blur-xl flex items-center justify-center p-4 md:p-8 opacity-0 pointer-events-none" onclick="closeCaseModal(event)">
  <div class="relative bg-[#faf8f2] border border-black/10 rounded-[32px] w-full max-w-5xl max-h-[85vh] overflow-y-auto p-6 md:p-12 text-dark shadow-2xl block space-y-8 modal-scroll" onclick="event.stopPropagation()">
    
    <!-- Close Button -->
    <button onclick="closeCaseModal(null)" class="absolute top-6 right-6 w-11 h-11 rounded-full border border-black/10 bg-white/85 backdrop-blur-md flex items-center justify-center text-dark/70 hover:text-dark hover:border-black/35 hover:scale-105 transition-all z-[100] shadow-sm" aria-label="Close details">
      <i class="fas fa-times text-sm"></i>
    </button>

    <!-- Modal Layout -->
    <div class="flex flex-col gap-8">
      
      <!-- Modal Header -->
      <div class="border-b border-black/5 pb-6">
        <span id="modal-category" class="text-[10px] font-black tracking-[0.25em] uppercase text-primary bg-primary/10 border border-primary/20 px-3 py-1 rounded-full inline-block mb-3">Category</span>
        <h2 id="modal-title" class="text-3xl md:text-5xl font-black uppercase tracking-wide text-dark leading-tight">Project Title</h2>
      </div>

      <!-- Main Columns Grid -->
      <div class="grid lg:grid-cols-12 gap-8 items-start">
        
        <!-- Left Column: Strategy & Description (7 cols) -->
        <div class="lg:col-span-7 flex flex-col gap-6">
          <div>
            <h4 class="text-xs font-black uppercase tracking-wider text-dark/40 mb-2">The Challenge</h4>
            <p id="modal-desc" class="text-dark/70 text-sm leading-relaxed">Description of the project and its goals.</p>
          </div>

          <div>
            <h4 class="text-xs font-black uppercase tracking-wider text-dark/40 mb-2">Our Strategy</h4>
            <div id="modal-strategy-card" class="bg-black/5 border border-black/5 p-5 rounded-2xl">
              <p id="modal-strategy" class="text-dark/80 text-sm leading-relaxed"></p>
            </div>
          </div>

          <div>
            <h4 class="text-xs font-black uppercase tracking-wider text-dark/40 mb-3">Expertises Delivered</h4>
            <div id="modal-services" class="flex flex-wrap gap-2">
              <!-- Services injected dynamically -->
            </div>
          </div>

          <!-- GrowBot Direct Integration CTA -->
          <div class="mt-4 pt-4 border-t border-black/5">
            <button id="modal-chatbot-cta" onclick="consultFromCase()" class="inline-flex items-center justify-center gap-2.5 bg-primary hover:bg-green-700 text-white font-extrabold text-xs uppercase tracking-widest px-6 py-4 rounded-xl shadow-lg shadow-primary/25 hover:shadow-primary/45 transition-all duration-300">
              <i class="fas fa-comments"></i> Consult With GrowBot About This Service
            </button>
          </div>
        </div>

        <!-- Right Column: Interactive Metrics & Browser Mockups (5 cols) -->
        <div class="lg:col-span-5 flex flex-col gap-6">
          
          <!-- Key Metrics Counter Display -->
          <div>
            <h4 class="text-xs font-black uppercase tracking-wider text-dark/40 mb-3">Verified Results</h4>
            <div class="grid grid-cols-2 gap-4">
              <!-- Metric 1 Card -->
              <div class="metric-card bg-white border border-black/5 rounded-2xl p-4 text-center shadow-sm">
                <p id="modal-metric1-label" class="text-[9px] font-black uppercase tracking-widest text-dark/40 mb-2">Metric 1</p>
                <div class="text-2xl font-black text-primary flex items-center justify-center gap-0.5">
                  <span id="modal-metric1-num-prefix"></span>
                  <span id="modal-metric1-num" class="counter-num">0</span>
                  <span id="modal-metric1-num-suffix" class="text-sm font-bold text-dark/80"></span>
                </div>
              </div>
              <!-- Metric 2 Card -->
              <div class="metric-card bg-white border border-black/5 rounded-2xl p-4 text-center shadow-sm">
                <p id="modal-metric2-label" class="text-[9px] font-black uppercase tracking-widest text-dark/40 mb-2">Metric 2</p>
                <div class="text-2xl font-black text-dark flex items-center justify-center gap-0.5">
                  <span id="modal-metric2-num-prefix"></span>
                  <span id="modal-metric2-num" class="counter-num">0</span>
                  <span id="modal-metric2-num-suffix" class="text-sm font-bold text-dark/80"></span>
                </div>
              </div>
            </div>
          </div>

          <!-- Premium Interactive Simulated Website Mockup Frame (Light mode wireframe) -->
          <div id="modal-mockup-section" class="flex flex-col gap-2">
            <h4 class="text-xs font-black uppercase tracking-wider text-dark/40">Interactive Wireframe Preview</h4>
            
            <div class="mockup-browser border border-black/10 bg-[#f0ede6] rounded-2xl overflow-hidden shadow-xl">
              <!-- Browser Header -->
              <div class="bg-[#e5dfd5] px-4 py-2.5 flex items-center gap-1.5 border-b border-black/5">
                <span class="w-2.5 h-2.5 rounded-full bg-red-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-500/80"></span>
                <div id="modal-mockup-url" class="bg-white/60 px-4 py-1 rounded-full text-[9px] text-dark/40 ml-4 w-52 truncate tracking-wide border border-black/5">https://wholeup.in/showcase</div>
              </div>
              
              <!-- Browser Viewport Container -->
              <div id="modal-mockup-viewport" class="mock-browser-scroll h-64 overflow-y-auto bg-[#faf8f2] p-4 relative scroll-smooth flex flex-col gap-4">
                <!-- Generated mockup contents will be injected here dynamically -->
              </div>
            </div>
            
            <p class="text-[10px] text-dark/30 text-center italic">↑ Scroll inside the browser to preview landing page architecture.</p>
          </div>

        </div>

      </div>

    </div>

  </div>
</div>

<!-- CLIENT SIDE PORTFOLIO ANIMATIONS & MODAL LOGIC -->
<script id="portfolio-data" type="application/json">
  {{{json portfolio}}}
</script>

<script>
  let portfolioData = [];
  try {
    portfolioData = JSON.parse(document.getElementById('portfolio-data').textContent);
  } catch (err) {
    console.error('Failed to parse portfolio JSON data:', err);
  }

  let activeModalSlug = '';

  // Initial positioning of sliding pill indicator
  window.addEventListener('DOMContentLoaded', () => {
    const activeTab = document.querySelector('.filter-tab.active-tab');
    if (activeTab && typeof gsap !== 'undefined') {
      const pill = document.getElementById('filter-pill');
      const container = document.getElementById('filter-tabs');
      const cRect = container.getBoundingClientRect();
      const bRect = activeTab.getBoundingClientRect();
      gsap.set(pill, {
        left: bRect.left - cRect.left,
        width: bRect.width
      });
    }
  });

  // GSAP-powered tab filtration
  function filterPortfolio(category, button) {
    // 1. Move sliding pill indicator
    const pill = document.getElementById('filter-pill');
    const container = document.getElementById('filter-tabs');
    if (pill && button && typeof gsap !== 'undefined') {
      const cRect = container.getBoundingClientRect();
      const bRect = button.getBoundingClientRect();
      
      // Update classes
      document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active-tab'));
      button.classList.add('active-tab');

      gsap.to(pill, {
        left: bRect.left - cRect.left,
        width: bRect.width,
        duration: 0.45,
        ease: 'power3.out'
      });
    }

    // 2. Animate and filter items
    const cards = document.querySelectorAll('.portfolio-card');
    cards.forEach(card => {
      const matches = category === 'all' || card.dataset.category === category;
      if (matches) {
        card.style.display = 'flex';
        if (typeof gsap !== 'undefined') {
          gsap.fromTo(card, 
            { opacity: 0, scale: 0.95, y: 15 },
            { opacity: 1, scale: 1, y: 0, duration: 0.5, ease: 'power2.out', clearProps: 'transform' }
          );
        }
      } else {
        card.style.display = 'none';
      }
    });

    // Refresh ScrollTrigger to update heights after filtering cards
    if (typeof ScrollTrigger !== 'undefined') {
      ScrollTrigger.refresh();
    }
  }

  // Immersive Modal Operations
  function openCaseModal(caseId) {
    const project = portfolioData.find(p => p.id === caseId);
    if (!project) return;
    
    activeModalSlug = project.slug;

    // Lock Body Scroll natively
    document.body.style.overflow = 'hidden';

    // Populate Text Fields
    document.getElementById('modal-category').innerText = project.categoryLabel;
    document.getElementById('modal-title').innerText = project.title;
    document.getElementById('modal-desc').innerText = project.description;
    document.getElementById('modal-strategy').innerText = project.caseInfo;
    document.getElementById('modal-mockup-url').innerText = `https://wholeup.in/portfolio/${project.slug}`;

    // Style elements based on category accent colors
    const categoryColor = project.tagColor;
    document.getElementById('modal-category').style.color = categoryColor;
    document.getElementById('modal-category').style.borderColor = colorMix(categoryColor, 20);
    document.getElementById('modal-category').style.backgroundColor = colorMix(categoryColor, 8);
    document.getElementById('modal-chatbot-cta').style.backgroundColor = categoryColor;

    // Theme the metrics cards
    const metricCards = document.querySelectorAll('.metric-card');
    metricCards.forEach(card => {
      card.style.borderColor = colorMix(categoryColor, 15);
      card.style.backgroundColor = colorMix(categoryColor, 4);
    });

    // Inject Tag Chips
    const tagsContainer = document.getElementById('modal-services');
    tagsContainer.innerHTML = '';
    project.services.forEach(tag => {
      const chip = document.createElement('span');
      chip.className = 'bg-white border border-black/5 text-dark/70 text-[10px] font-semibold uppercase tracking-wider px-3.5 py-1.5 rounded-lg shadow-sm';
      chip.innerText = tag;
      tagsContainer.appendChild(chip);
    });

    // Reset and Populate Metrics Details
    document.getElementById('modal-metric1-label').innerText = project.metric1.split(' ').slice(1).join(' ') || 'Metric 1';
    document.getElementById('modal-metric2-label').innerText = project.metric2.split(' ').slice(1).join(' ') || 'Metric 2';

    // Show/Hide Browser Mockups & Build Wireframe Viewport Contents
    const mockupSection = document.getElementById('modal-mockup-section');
    const viewport = document.getElementById('modal-mockup-viewport');
    viewport.innerHTML = ''; // reset

    if (project.category === 'web' || project.category === 'ai') {
      mockupSection.classList.remove('hidden');
      buildBrowserWireframe(project, viewport);
    } else {
      mockupSection.classList.add('hidden');
    }

    // Modal Opening Timeline Animations (GSAP)
    const modal = document.getElementById('case-modal');
    modal.classList.remove('pointer-events-none');
    
    if (typeof lenis !== 'undefined' && lenis) lenis.stop(); // stop background scrolling
    
    if (typeof gsap !== 'undefined') {
      const modalBox = modal.querySelector('.relative');
      
      const tl = gsap.timeline();
      
      tl.to(modal, {
        opacity: 1,
        duration: 0.3,
        ease: 'power2.out'
      });
      
      tl.fromTo(modalBox, {
        y: 60,
        opacity: 0,
        scale: 0.9
      }, {
        y: 0,
        opacity: 1,
        scale: 1,
        duration: 0.55,
        ease: 'power4.out'
      }, "-=0.25");

      // Animate Metrics Numbers Counting Up dynamically
      animateCounter('modal-metric1-num', 0, project.metric1Val, project.metric1Prefix, project.metric1Suffix);
      animateCounter('modal-metric2-num', 0, project.metric2Val, project.metric2Prefix, project.metric2Suffix);
      
      // Auto Scroll inside simulated browser frame
      if (project.category === 'web' || project.category === 'ai') {
        tl.to(viewport, {
          scrollTop: viewport.scrollHeight - viewport.clientHeight,
          duration: 4.5,
          ease: 'power1.inOut',
          delay: 0.5
        });
        tl.to(viewport, {
          scrollTop: 0,
          duration: 2.0,
          ease: 'power2.out'
        });
      }
    } else {
      modal.style.opacity = '1';
      document.getElementById('modal-metric1-num').innerText = project.metric1;
      document.getElementById('modal-metric2-num').innerText = project.metric2;
    }
  }

  function closeCaseModal(event) {
    if (event && event.target !== document.getElementById('case-modal') && event.type === 'click') return;
    
    const modal = document.getElementById('case-modal');
    modal.classList.add('pointer-events-none');
    
    // Unlock body scroll natively
    document.body.style.overflow = '';
    
    if (typeof lenis !== 'undefined' && lenis) lenis.start(); // restore background scrolling
    
    if (typeof gsap !== 'undefined') {
      const modalBox = modal.querySelector('.relative');
      const tl = gsap.timeline({
        onComplete: () => {
          gsap.set(modal, { opacity: 0 });
        }
      });
      
      tl.to(modalBox, {
        y: 40,
        opacity: 0,
        scale: 0.95,
        duration: 0.35,
        ease: 'power3.in'
      });
      
      tl.to(modal, {
        opacity: 0,
        duration: 0.3,
        ease: 'power2.in'
      }, "-=0.2");
    } else {
      modal.style.opacity = '0';
    }
  }

  // GSAP Counter Animation Handler
  function animateCounter(elementId, start, end, prefix, suffix) {
    const obj = { val: start };
    const el = document.getElementById(elementId);
    if (!el) return;

    if (typeof gsap !== 'undefined') {
      gsap.to(obj, {
        val: end,
        duration: 1.8,
        ease: 'power3.out',
        onUpdate: () => {
          // Format integers or decimals nicely
          let valueString = Number(obj.val % 1 === 0 ? obj.val.toFixed(0) : obj.val.toFixed(1)).toLocaleString('en-US');
          
          // Custom overrides for massive numbers
          if (end >= 1000) {
            valueString = (obj.val / 1000).toFixed(0) + 'K';
          }
          
          el.innerText = `${prefix || ''}${valueString}`;
          
          // Append custom suffix
          document.getElementById(elementId + '-prefix').innerText = prefix || '';
          document.getElementById(elementId + '-suffix').innerText = suffix || '';
        }
      });
    } else {
      el.innerText = end;
    }
  }

  // Helper utility to programmatically calculate color-mix
  function colorMix(baseHex, percent) {
    return `color-mix(in srgb, ${baseHex} ${percent}%, transparent)`;
  }

