<!-- SERVICE HERO -->
<section class="page-hero px-6" style="background:{{service.bgColor}}">
  <div class="max-w-5xl mx-auto gs-reveal">
    <a href="/services" class="inline-flex items-center gap-2 text-sm font-bold text-dark/50 hover:text-dark mb-8 transition"><i class="fas fa-arrow-left"></i> All Services</a>
    <div class="flex items-center gap-5 mb-8">
      <div class="w-20 h-20 rounded-3xl flex items-center justify-center text-4xl" style="background:white;color:{{service.color}}">
        <i class="{{service.icon}}"></i>
      </div>
      <div>
        <p class="text-sm font-bold uppercase tracking-widest mb-1" style="color:{{service.color}}">{{service.result}}</p>
        <h1 class="text-4xl md:text-5xl font-black uppercase tracking-widest text-dark">{{service.title}}</h1>
      </div>
    </div>
    <p class="text-2xl font-bold text-dark/80 mb-4">{{service.tagline}}</p>
    <p class="text-lg text-dark/60 font-medium max-w-3xl">{{service.description}}</p>
  </div>
</section>

<!-- CONTENT -->
<section class="py-24 bg-white px-6">
  <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-16">
    <div class="md:col-span-2">
      <h2 class="text-3xl font-black uppercase tracking-widest text-dark mb-8">What's Included</h2>
      <div class="space-y-4 mb-12">
        {{#each service.features}}
        <div class="flex items-center gap-4 p-5 bg-cream rounded-2xl border border-black/5 gs-reveal">
          <div class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center text-white flex-shrink-0"><i class="fas fa-check text-sm"></i></div>
          <span class="font-bold text-dark">{{this}}</span>
        </div>
        {{/each}}
      </div>
      <div class="bg-cream rounded-3xl p-10 border border-black/5 gs-reveal">
        <h3 class="text-2xl font-black uppercase tracking-widest text-dark mb-4">Expected Results</h3>
        <div class="flex items-center gap-6 flex-wrap">
          <div class="text-center">
            <div class="text-4xl font-black text-primary mb-1">{{service.result}}</div>
            <div class="text-sm font-bold text-dark/50 uppercase tracking-widest">Typical Outcome</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-black text-primary mb-1">{{service.timeline}}</div>
            <div class="text-sm font-bold text-dark/50 uppercase tracking-widest">Timeline</div>
          </div>
        </div>
      </div>
    </div>
    <div>
      <div class="bg-dark rounded-3xl p-8 text-white sticky top-32 gs-reveal">
        <h3 class="text-xl font-black uppercase tracking-widest mb-4">Get Started</h3>
        <p class="text-white/60 text-sm font-medium mb-8">Book a free strategy call and find out how we can deliver results for your business.</p>
        <a href="/contact" class="block bg-primary text-white text-center py-4 rounded-xl font-bold uppercase tracking-widest text-sm hover:bg-green-500 transition mb-4 magnetic-btn">Book Free Call</a>
        <a href="/pricing" class="block border border-white/20 text-white text-center py-4 rounded-xl font-bold uppercase tracking-widest text-sm hover:bg-white/10 transition magnetic-btn">View Pricing</a>
        <div class="mt-8 pt-8 border-t border-white/10">
          <p class="text-xs font-bold uppercase tracking-widest text-white/40 mb-4">Direct Contact</p>
          <a href="tel:+919426846035" class="flex items-center gap-3 text-sm text-white/70 hover:text-white transition mb-3 font-medium"><i class="fas fa-phone text-primary"></i> +91 94268 46035</a>
          <a href="mailto:wholeup.agency@gmail.com" class="flex items-center gap-3 text-sm text-white/70 hover:text-white transition font-medium"><i class="fas fa-envelope text-primary"></i> wholeup.agency@gmail.com</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- RELATED SERVICES -->
{{#if related}}
<section class="py-24 bg-cream px-6 border-t border-black/5">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl font-black uppercase tracking-widest text-dark mb-12 gs-reveal">Related Services</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {{#each related}}
      <a href="/services/{{slug}}" class="glass-card rounded-[28px] p-8 gs-reveal block hover:-translate-y-1 transition-all">
        <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl mb-5" style="background:{{bgColor}};color:{{color}}"><i class="{{icon}}"></i></div>
        <h3 class="text-lg font-black uppercase tracking-wider text-dark mb-2">{{title}}</h3>
        <p class="text-dark/60 text-sm font-medium mb-4">{{description}}</p>
        <span class="text-primary text-sm font-bold">Learn More →</span>
      </a>
      {{/each}}
    </div>
  </div>
</section>
{{/if}}
