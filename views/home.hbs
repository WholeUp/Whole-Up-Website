<!-- CLIENT SIDE GSAP ADVANCED HOMEPAGE TIMELINE & SCROLL SCRIPTS -->
<script>
  window.addEventListener('DOMContentLoaded', () => {
    // Only run if GSAP is available
    if (typeof gsap !== 'undefined') {
      // ════ HERO LOAD ANIMATIONS ════
      const heroTl = gsap.timeline();
      
      gsap.set('.hero-reveal-item', { opacity: 0, y: 30 });
      gsap.set('.title-line-text', { translateY: '100%', opacity: 0 });
      gsap.set('#hero-visual-block .absolute', { opacity: 0, scale: 0.9 });
      
      heroTl.to('.hero-reveal-item', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.12,
        ease: 'power3.out'
      });

      heroTl.to('.title-line-text', {
        translateY: '0%',
        opacity: 1,
        duration: 1.1,
        stagger: 0.12,
        ease: 'power4.out'
      }, 0.15);
      
      heroTl.to('#hero-visual-block .absolute', {
        opacity: 1,
        scale: 1,
        duration: 1.0,
        stagger: 0.15,
        ease: 'back.out(1.2)'
      }, "-=0.7");

      // ════ HERO MOUSE PARALLAX EFFECT ════
      const heroSection = document.getElementById('home');
      if (heroSection) {
        heroSection.addEventListener('mousemove', e => {
          const { width, height } = heroSection.getBoundingClientRect();
          const moveX = (e.clientX - width / 2) / width;
          const moveY = (e.clientY - height / 2) / height;
          
          gsap.to('.hero-parallax-1', { x: moveX * 22, y: moveY * 22, duration: 0.7, ease: 'power2.out' });
          gsap.to('.hero-parallax-2', { x: moveX * -32, y: moveY * -32, duration: 0.7, ease: 'power2.out' });
          gsap.to('.hero-parallax-3', { x: moveX * 38, y: moveY * -12, duration: 0.7, ease: 'power2.out' });
          
          // Parallax for decorative background particles
          gsap.to('.anim-particle-1', { x: moveX * 45, y: moveY * 45, duration: 0.9, ease: 'power1.out' });
          gsap.to('.anim-particle-2', { x: moveX * -55, y: moveY * 55, duration: 0.9, ease: 'power1.out' });
          gsap.to('.anim-particle-3', { x: moveX * 65, y: moveY * -65, duration: 0.9, ease: 'power1.out' });
          gsap.to('.anim-particle-4', { x: moveX * -25, y: moveY * -25, duration: 0.9, ease: 'power1.out' });
          gsap.to('.anim-particle-5', { x: moveX * 75, y: moveY * 35, duration: 0.9, ease: 'power1.out' });
          gsap.to('.anim-shape-ring', { x: moveX * -40, y: moveY * 40, duration: 0.85, ease: 'power2.out' });
          gsap.to('.anim-shape-square', { x: moveX * 50, y: moveY * -30, duration: 0.85, ease: 'power2.out' });
          gsap.to('.anim-shape-star', { x: moveX * -60, y: moveY * -50, duration: 0.85, ease: 'power2.out' });
          gsap.to('.anim-shape-bolt', { x: moveX * 30, y: moveY * 60, duration: 0.85, ease: 'power2.out' });
        });
        
        heroSection.addEventListener('mouseleave', () => {
          gsap.to('.hero-parallax-1, .hero-parallax-2, .hero-parallax-3, .anim-particle-1, .anim-particle-2, .anim-particle-3, .anim-particle-4, .anim-particle-5, .anim-shape-ring, .anim-shape-square, .anim-shape-star, .anim-shape-bolt', {
            x: 0,
            y: 0,
            duration: 1.0,
            ease: 'power3.out'
          });
        });
      }

      // ════ SPOTLIGHT HOVER EFFECTS ════
      const updateSpotlight = (e, card) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        card.style.setProperty('--mouse-x', `${x}px`);
        card.style.setProperty('--mouse-y', `${y}px`);
      };

      document.querySelectorAll('.services-card, .marquee-card').forEach(card => {
        card.addEventListener('mousemove', e => updateSpotlight(e, card));
      });

      // ════ STATS SECTION COUNT-UP & REVEAL ════
      if (typeof ScrollTrigger !== 'undefined') {
        // Staggered fade and 3D tilt reveal for stat column cards
        gsap.fromTo('#stats-section .home-stats-card',
          { y: 45, scale: 0.9, rotationX: 15, opacity: 0 },
          {
            y: 0, scale: 1, rotationX: 0, opacity: 1,
            duration: 1.0,
            stagger: 0.12,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: '#stats-section',
              start: 'top 90%',
              once: true
            }
          }
        );

        gsap.utils.toArray('.stat-count').forEach(stat => {
          const target = parseFloat(stat.dataset.target);
          const decimals = parseInt(stat.dataset.decimals) || 0;
          const countObj = { val: 0 };
          
          gsap.to(countObj, {
            val: target,
            scrollTrigger: {
              trigger: '#stats-section',
              start: 'top 85%',
              once: true
            },
            duration: 2.2,
            ease: 'power3.out',
            onUpdate: () => {
              stat.innerText = countObj.val.toFixed(decimals);
            }
          });
        });

        // ════ PROCESS TIMELINE DRAWING ════
        const connector = document.getElementById('process-connector-line');
        if (connector) {
          gsap.fromTo(connector, {
            scaleX: 0,
            transformOrigin: 'left center'
          }, {
            scaleX: 1,
            scrollTrigger: {
              trigger: '#process-timeline',
              start: 'top 75%',
              end: 'bottom 60%',
              scrub: 1.2
            },
            ease: 'none'
          });
        }

        // Sequential step lighting
        document.querySelectorAll('.process-step-card').forEach((card, idx) => {
          gsap.from(card, {
            y: 40,
            opacity: 0.15,
            scale: 0.94,
            duration: 0.8,
            scrollTrigger: {
              trigger: card,
              start: 'top 80%',
              toggleActions: 'play none none reverse'
            },
            ease: 'power2.out',
            onStart: () => {
              // Pulse the step number/icon
              gsap.to(card.querySelector('.process-icon'), {
                borderColor: '#16A34A',
                backgroundColor: 'rgba(22, 163, 74, 0.2)',
                scale: 1.1,
                duration: 0.4,
                yoyo: true,
                repeat: 1
              });
            }
          });
        });

        // ════ PORTFOLIO STAGGERED GRID REVEAL ════
        gsap.fromTo('#portfolio-section .home-portfolio-item',
          { y: 80, skewY: 2.5, opacity: 0 },
          {
            y: 0, skewY: 0, opacity: 1,
            duration: 1.1,
            stagger: 0.12,
            ease: 'power4.out',
            scrollTrigger: {
              trigger: '#portfolio-section',
              start: 'top 85%',
              once: true
            }
          }
        );

        // ════ TESTIMONIALS VELOCITY SKEW EFFECT ════
        let velocity = 0;
        let lastScrollY = window.scrollY;
        let skewTimeOut;
        window.addEventListener('scroll', () => {
          const currentY = window.scrollY;
          velocity = currentY - lastScrollY;
          lastScrollY = currentY;

          const maxSkew = 12;
          const skewVal = Math.min(maxSkew, Math.max(-maxSkew, velocity * 0.075));

          gsap.to('.marquee-card', {
            skewX: skewVal,
            duration: 0.35,
            ease: 'power1.out',
            overwrite: 'auto'
          });

          // Reset skew after scroll stops
          clearTimeout(skewTimeOut);
          skewTimeOut = setTimeout(() => {
            gsap.to('.marquee-card', {
              skewX: 0,
              duration: 0.45,
              ease: 'power2.out'
            });
          }, 80);
        });

        // ════ BLOG GRID REVEALS ════
        gsap.fromTo('#blog-section .home-blog-item',
          { scale: 0.94, y: 40, opacity: 0 },
          {
            scale: 1, y: 0, opacity: 1,
            duration: 0.9,
            stagger: 0.1,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: '#blog-section',
              start: 'top 90%',
              once: true
            }
          }
        );
      }

      // ════ SAFETY FALLBACK: ensure cards always visible after 2s ════
      setTimeout(() => {
        [
          '#stats-section .home-stats-card',
          '#portfolio-section .home-portfolio-item',
          '#blog-section .home-blog-item'
        ].forEach(sel => {
          document.querySelectorAll(sel).forEach(el => {
            if (parseFloat(getComputedStyle(el).opacity) < 0.5) {
              el.style.opacity = '1';
              el.style.transform = 'none';
            }
          });
        });
      }, 2000);

      // ════ ROI CALCULATOR HOLOGRAPHIC REFLECTION ════
      const roiPanel = document.getElementById('roi-result-card');
      if (roiPanel) {
        roiPanel.addEventListener('mousemove', (e) => {
          const rect = roiPanel.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const xPct = (x / rect.width) * 100;
          const yPct = (y / rect.height) * 100;
          roiPanel.style.background = `linear-gradient(${135 + xPct*0.18}deg, rgba(22, 163, 74, 0.18) 0%, rgba(6, 182, 212, 0.22) ${xPct}%, rgba(22, 163, 74, 0.1) 100%)`;
        });
        roiPanel.addEventListener('mouseleave', () => {
          roiPanel.style.background = '';
        });
      }

      // ════ CTA BUTTON GLOW AURA TRACKER ════
      const ctaSection = document.getElementById('cta-section');
      if (ctaSection) {
        const glowAura = document.createElement('div');
        glowAura.style.cssText = 'position:absolute; width:450px; height:450px; border-radius:50%; background:radial-gradient(circle, rgba(22,163,74,0.1) 0%, rgba(22,163,74,0) 70%); pointer-events:none; z-index:0; transition: transform 0.1s ease-out; opacity:0;';
        ctaSection.insertBefore(glowAura, ctaSection.firstChild);

        ctaSection.addEventListener('mousemove', (e) => {
          const rect = ctaSection.getBoundingClientRect();
          const x = e.clientX - rect.left - 225;
          const y = e.clientY - rect.top - 225;
          glowAura.style.opacity = '1';
          glowAura.style.transform = `translate3d(${x}px, ${y}px, 0)`;
        });

        ctaSection.addEventListener('mouseleave', () => {
          glowAura.style.opacity = '0';
        });
      }
    }
  });
</script>

