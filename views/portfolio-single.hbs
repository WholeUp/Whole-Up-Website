<!-- Web Synth Audio & Simulation Scripts -->
<script>
  let mainChartInstance = null;

  // Initialize live chart on load
  window.addEventListener('DOMContentLoaded', () => {
    const ctx = document.getElementById('apex-live-chart').getContext('2d');
    
    // Create initial chart data
    mainChartInstance = new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['10:00', '11:00', '12:00', '13:00', '14:00', '15:00'],
        datasets: [{
          label: 'TATA MOTORS Price (₹)',
          data: [920, 935, 942, 955, 968, 984.50],
          borderColor: '#10B981',
          borderWidth: 3,
          backgroundColor: (context) => {
            const chart = context.chart;
            const {ctx, chartArea} = chart;
            if (!chartArea) return null;
            const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
            gradient.addColorStop(0, 'rgba(16, 185, 129, 0.25)');
            gradient.addColorStop(1, 'rgba(16, 185, 129, 0.0)');
            return gradient;
          },
          fill: true,
          tension: 0.4,
          pointRadius: 6,
          pointBackgroundColor: '#10B981',
          pointHoverRadius: 8
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          x: {
            grid: { color: 'rgba(255, 255, 255, 0.05)' },
            ticks: { color: 'rgba(255, 255, 255, 0.4)' }
          },
          y: {
            grid: { color: 'rgba(255, 255, 255, 0.05)' },
            ticks: { color: 'rgba(255, 255, 255, 0.4)' }
          }
        }
      }
    });

    // Start auto indices simulation
    setInterval(simulateIndicesFluc, 4000);
  });

  // Handle stock selection and update chart dynamically
  function selectStock(symbol, chartData, price, changeText) {
    document.getElementById('selected-chart-symbol').textContent = symbol;
    document.getElementById('selected-chart-price').textContent = '₹' + price;
    
    // Update chart dataset
    if (mainChartInstance) {
      mainChartInstance.data.datasets[0].label = `${symbol} Price (₹)`;
      mainChartInstance.data.datasets[0].data = chartData;
      mainChartInstance.update();
    }

    // Play sleek click synth sound
    playBeepSound(440, 0.15); // A4 note
  }

  // Simulate market indices fluctuation
  function simulateIndicesFluc() {
    const nifty = document.getElementById('nifty-val');
    const sensex = document.getElementById('sensex-val');
    
    if (nifty && sensex) {
      const currentNifty = parseFloat(nifty.textContent.replace(/,/g, ''));
      const currentSensex = parseFloat(sensex.textContent.replace(/,/g, ''));
      
      const flucNifty = (currentNifty + (Math.random() * 20 - 10)).toFixed(2);
      const flucSensex = (currentSensex + (Math.random() * 80 - 40)).toFixed(2);
      
      nifty.textContent = parseFloat(flucNifty).toLocaleString('en-IN', {minimumFractionDigits: 2});
      sensex.textContent = parseFloat(flucSensex).toLocaleString('en-IN', {minimumFractionDigits: 2});
    }
  }

  // Live scanner stimulation logic
  function triggerSimulatedScan() {
    const box = document.getElementById('signals-scroll-box');
    const stockNames = ["INFOSYS", "SBI BANK", "ITC", "TCS", "BAJAJ FINANCE", "WIPRO", "MARUTI", "JIO FINANCIAL"];
    const patterns = ["Bullish Flag", "Triangle Breakout", "Double Bottom", "Rounding Bottom", "Wedge Pattern"];
    
    const randomStock = stockNames[Math.floor(Math.random() * stockNames.length)];
    const randomPattern = patterns[Math.floor(Math.random() * patterns.length)];
    const randomPrice = (Math.random() * 2000 + 300).toFixed(2);
    const randomVol = (Math.random() * 4 + 0.5).toFixed(1) + "M";
    const randomProb = (Math.random() * 8 + 74).toFixed(1) + "%";
    
    // Generate random price list for chart
    const pricesList = Array.from({length: 6}, () => Math.floor(Math.random() * 50 + parseFloat(randomPrice) - 25));
    pricesList.push(parseFloat(randomPrice));

    // Create new signal card
    const div = document.createElement('div');
    div.className = "flex items-start gap-4 p-4 border border-emerald-500/30 rounded-2xl bg-emerald-500/5 hover:border-emerald-400 transition-all duration-200 cursor-pointer group bg-emerald-500/10";
    div.onclick = () => selectStock(randomStock, pricesList, parseFloat(randomPrice).toLocaleString('en-IN', {minimumFractionDigits: 2}), '+1.5%');
    div.innerHTML = `
      <div class="w-10 h-10 rounded-xl bg-emerald-500/10 text-emerald-400 flex items-center justify-center text-lg flex-shrink-0">
        <i class="fas fa-arrow-trend-up"></i>
      </div>
      <div class="flex-grow">
        <div class="flex justify-between items-start">
          <div>
            <h4 class="text-sm font-black uppercase tracking-wider text-white group-hover:text-emerald-400 transition-colors">${randomStock}</h4>
            <p class="text-[9px] text-white/40 font-mono">CMP: ₹${parseFloat(randomPrice).toLocaleString('en-IN', {minimumFractionDigits: 2})} | Vol: ${randomVol}</p>
          </div>
          <span class="text-[9px] font-black px-2.5 py-0.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 uppercase tracking-widest">Bullish</span>
        </div>
        <div class="flex items-center justify-between mt-3 text-[10px] text-white/60 font-semibold border-t border-white/5 pt-2">
          <span>Pattern: <strong>${randomPattern}</strong></span>
          <span class="text-emerald-400">Prob: ${randomProb}</span>
        </div>
      </div>
    `;

    // Prepend and animate
    box.insertBefore(div, box.firstChild);
    playBeepSound(880, 0.25); // Trigger sound alert

    if (typeof gsap !== 'undefined') {
      gsap.from(div, { opacity: 0, scale: 0.9, duration: 0.45, ease: 'back.out(1.5)' });
      gsap.to(div, { backgroundColor: 'rgba(16, 185, 129, 0.05)', delay: 1.2, duration: 0.8 });
    }
  }

  // Web Audio synth player
  function playBeepSound(freq, duration) {
    try {
      const context = new (window.AudioContext || window.webkitAudioContext)();
      const osc = context.createOscillator();
      const gain = context.createGain();
      
      osc.type = 'sine';
      osc.frequency.setValueAtTime(freq, context.currentTime);
      gain.gain.setValueAtTime(0.08, context.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, context.currentTime + duration);
      
      osc.connect(gain);
      gain.connect(context.destination);
      
      osc.start();
      osc.stop(context.currentTime + duration);
    } catch(e) {}
  }
</script>
