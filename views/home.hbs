    </div>
    
    <!-- Connected horizontal progress bar line (desktop only) -->
    <div class="process-connector" id="process-connector-line"></div>
    
    <div class="grid md:grid-cols-4 gap-8 relative z-10">
      
      <!-- Step 1 -->
      <div class="text-center relative group process-step-card">
        <div class="w-16 h-16 rounded-2xl bg-primary/10 border border-primary/30 flex items-center justify-center text-primary text-2xl mx-auto mb-6 transition-all duration-500 group-hover:scale-110 group-hover:border-primary group-hover:bg-primary/20 process-icon"><i class="fas fa-search"></i></div>
