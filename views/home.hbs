<!-- CUSTOM STYLE SPECIFICATIONS FOR THE ADVANCED HOMEPAGE -->
<style>
  /* Ambient Blur Blobs */
  .hero-blur-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(130px);
    opacity: 0.12;
    pointer-events: none;
    z-index: 0;
    will-change: transform;
  }
  .hero-blob-1 {
    width: 450px;
    height: 450px;
    background: #16A34A;
    top: 5%;
    left: -10%;
    animation: blobFloat1 22s infinite alternate ease-in-out;
  }
  .hero-blob-2 {
    width: 500px;
    height: 500px;
    background: #06B6D4;
    bottom: 5%;
    right: -10%;
    animation: blobFloat2 28s infinite alternate ease-in-out;
  }

  @keyframes blobFloat1 {
    0% { transform: translate(0px, 0px) scale(1) rotate(0deg); }
    33% { transform: translate(40px, -60px) scale(1.08) rotate(6deg); }
    66% { transform: translate(-30px, 30px) scale(0.95) rotate(-4deg); }
    100% { transform: translate(0px, 0px) scale(1) rotate(0deg); }
  }
  @keyframes blobFloat2 {
    0% { transform: translate(0px, 0px) scale(1) rotate(0deg); }
    50% { transform: translate(-50px, 50px) scale(1.06) rotate(-7deg); }
    100% { transform: translate(0px, 0px) scale(1) rotate(0deg); }
  }
  
  /* Services Glow Styles */
  .services-card {
    --theme-color: var(--service-color, #16A34A);
    transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
    border: 1px solid rgba(0, 0, 0, 0.05);
  }
  .services-card:hover {
    transform: translateY(-8px);
    border-color: color-mix(in srgb, var(--theme-color) 35%, transparent);
    box-shadow: 0 20px 40px color-mix(in srgb, var(--theme-color) 8%, transparent);
  }

  /* Testimonials Marquee Track (Infinite Scrolling Row) */
  .marquee-wrapper {
    overflow: hidden;
    width: 100%;
    position: relative;
    padding: 16px 0;
  }
  .marquee-track {
    display: flex;
    gap: 24px;
    width: max-content;
    animation: marqueeScroll 45s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
  .marquee-card {
    width: 320px;
    flex-shrink: 0;
  }
  @keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Process Timeline Line Connector */
  .process-connector {
    position: absolute;
    top: 32px;
    left: 12%;
    right: 12%;
    height: 2px;
    background: linear-gradient(to right, rgba(22, 163, 74, 0.1) 0%, rgba(22, 163, 74, 0.8) 50%, rgba(22, 163, 74, 0.1) 100%);
    z-index: 1;
  }
  @media(max-width: 767px) {
    .process-connector { display: none; }
  }

  /* Slider Custom Track override for calculator */
  .range-slider {
    background: rgba(255, 255, 255, 0.08);
  }
</style>

