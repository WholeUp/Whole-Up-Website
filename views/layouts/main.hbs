<div id="debug-error-panel" style="display: none; background: #fee2e2; color: #991b1b; border: 2px solid #f87171; padding: 20px; font-family: monospace; font-size: 14px; position: fixed; top: 80px; left: 20px; right: 20px; z-index: 9999999; border-radius: 12px; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); max-height: 400px; overflow-y: auto;">
  <h3 style="margin-top: 0; font-weight: bold; font-size: 16px;">⚠️ Client-Side JS Error Detected:</h3>
  <pre id="debug-error-log" style="white-space: pre-wrap; margin: 0;"></pre>
  <button onclick="document.getElementById('debug-error-panel').style.display='none'" style="margin-top: 12px; background: #ef4444; color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-weight: bold;">Close Panel</button>
</div>
<script>
  window.addEventListener('error', function(event) {
    const panel = document.getElementById('debug-error-panel');
    const log = document.getElementById('debug-error-log');
    if (panel && log) {
      panel.style.display = 'block';
      log.textContent += event.message + '\n  at ' + event.filename + ':' + event.lineno + ':' + event.colno + '\n\n';
    }
  });
  window.addEventListener('unhandledrejection', function(event) {
    const panel = document.getElementById('debug-error-panel');
    const log = document.getElementById('debug-error-log');
    if (panel && log) {
      panel.style.display = 'block';
      log.textContent += 'Unhandled Promise Rejection: ' + event.reason + '\n\n';
    }
  });
</script>

