<script>
// Pre-fill parameters if redirected from ROI calculator
window.addEventListener('DOMContentLoaded', () => {
  const params = new URLSearchParams(window.location.search);
  if (params.has('spend')) {
    const spend = params.get('spend');
    const roas = params.get('roas');
    const cpl = params.get('cpl');
    const msgArea = document.querySelector('textarea[name="message"]');
    if (msgArea) {
      msgArea.value = `I calculated my ROI using the calculator. My parameters: Monthly Ad Spend: ₹${parseInt(spend).toLocaleString('en-IN')}, Target ROAS: ${roas}x, Average CPL: ₹${cpl}. I'd like a custom marketing strategy based on these details.`;
    }
  }

  // ════ 2D PLEXUS CANVAS SYSTEM ════
  const canvas = document.getElementById('contact-mesh-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    let width = canvas.width = canvas.offsetWidth;
    let height = canvas.height = canvas.offsetHeight;

    window.addEventListener('resize', () => {
      width = canvas.width = canvas.offsetWidth;
      height = canvas.height = canvas.offsetHeight;
    });

    const particles = [];
    const maxParticles = 45;

    class Particle {
      constructor() {
        this.x = Math.random() * width;
        this.y = Math.random() * height;
        this.vx = (Math.random() - 0.5) * 0.45;
        this.vy = (Math.random() - 0.5) * 0.45;
        this.radius = Math.random() * 2 + 1;
      }
      update() {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > width) this.vx *= -1;
        if (this.y < 0 || this.y > height) this.vy *= -1;
      }
      draw() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(22, 163, 74, 0.12)';
        ctx.fill();
      }
    }

    for (let i = 0; i < maxParticles; i++) {
      particles.push(new Particle());
    }

    let mouse = { x: null, y: null };
    const contactSection = canvas.parentElement;
    contactSection.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });
    contactSection.addEventListener('mouseleave', () => {
      mouse.x = null;
      mouse.y = null;
    });

    function drawPlexus() {
      ctx.clearRect(0, 0, width, height);

      particles.forEach(p => {
        p.update();
        p.draw();
      });

      // Draw lines between close particles
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < 105) {
            const alpha = (1 - dist / 105) * 0.08;
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(22, 163, 74, ${alpha})`;
            ctx.lineWidth = 1;
            ctx.stroke();
          }
        }
      }

      // Draw lines to mouse cursor
      if (mouse.x !== null && mouse.y !== null) {
        particles.forEach(p => {
          const dx = p.x - mouse.x;
          const dy = p.y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < 160) {
            const alpha = (1 - dist / 160) * 0.15;
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(mouse.x, mouse.y);
            ctx.strokeStyle = `rgba(22, 163, 74, ${alpha})`;
            ctx.lineWidth = 1.2;
            ctx.stroke();
          }
        });
      }

      requestAnimationFrame(drawPlexus);
    }
    drawPlexus();
  }

  // ════ FLOATING LABEL INPUT GLOWS ════
  const inputs = document.querySelectorAll('#contact-form input, #contact-form textarea, #contact-form select');
  inputs.forEach(input => {
    const parent = input.parentElement;
    const label = parent ? parent.querySelector('label') : null;
    
    if (label) {
      input.addEventListener('focus', () => {
        label.style.color = '#16A34A';
        label.style.transform = 'translateY(-2px) scale(0.98)';
        label.style.transformOrigin = 'left center';
        label.style.transition = 'all 0.3s ease';
        input.style.boxShadow = '0 0 0 4px rgba(22, 163, 74, 0.1)';
      });
      input.addEventListener('blur', () => {
        label.style.color = '';
        label.style.transform = '';
        input.style.boxShadow = '';
      });
    }
  });

  // ════ MAGNETIC SUBMIT BUTTON ════
  const submitBtn = document.getElementById('submit-btn');
  if (submitBtn && typeof gsap !== 'undefined') {
    submitBtn.addEventListener('mousemove', (e) => {
      const rect = submitBtn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      
      gsap.to(submitBtn, {
        x: x * 0.35,
        y: y * 0.35,
        duration: 0.3,
        ease: 'power2.out'
      });
    });
    submitBtn.addEventListener('mouseleave', () => {
      gsap.to(submitBtn, {
        x: 0,
        y: 0,
        duration: 0.5,
        ease: 'elastic.out(1, 0.5)'
      });
    });
  }
});

document.getElementById('contact-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnIcon = document.getElementById('btn-icon');
  const errBox = document.getElementById('form-error');

  btnText.textContent = 'Sending...';
  btnIcon.className = 'fas fa-spinner fa-spin';
  btn.disabled = true;
  errBox.classList.add('hidden');

  const formData = new FormData(this);
  const data = Object.fromEntries(formData.entries());

  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    const result = await res.json();
    if (result.success) {
      this.style.display = 'none';
      document.getElementById('form-success').classList.remove('hidden');
    } else {
      errBox.textContent = result.message || 'Something went wrong. Please try again.';
      errBox.classList.remove('hidden');
      btnText.textContent = 'Submit Request';
      btnIcon.className = 'fas fa-arrow-right';
      btn.disabled = false;
    }
  } catch(err) {
    errBox.textContent = 'Network error. Please try again or contact us directly.';
    errBox.classList.remove('hidden');
    btnText.textContent = 'Submit Request';
    btnIcon.className = 'fas fa-arrow-right';
    btn.disabled = false;
  }
});
</script>
