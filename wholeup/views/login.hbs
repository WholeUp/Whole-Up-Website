<!-- HERO / LOGIN SECTION -->
<section class="min-h-screen pt-36 pb-20 relative overflow-hidden px-4 md:px-6 flex items-center bg-grid select-none">
  <!-- Glowing Background Ambience -->
  <div class="hero-blur-blob hero-blob-1"></div>
  <div class="hero-blur-blob hero-blob-2"></div>

  <div class="max-w-md mx-auto w-full relative z-10 gs-reveal">
    <div class="glass-card rounded-[40px] p-8 md:p-10 border border-black/5 bg-white/80 shadow-[0_20px_50px_-10px_rgba(0,0,0,0.08)]">
      
      <!-- Brand Logo / Header -->
      <div class="text-center mb-8">
        <div class="w-16 h-16 rounded-3xl bg-primary/10 flex items-center justify-center text-primary text-3xl mx-auto mb-4 border border-primary/20 shadow-inner">
          <i class="fas fa-lock"></i>
        </div>
        <h1 class="text-2xl font-black uppercase tracking-wider text-dark mb-2">Client Portal</h1>
        <p class="text-xs text-dark/50 font-medium mb-4">Access your custom marketing automations, lead pipeline, and performance analytics.</p>
        {{#if error}}
        <div class="p-3 bg-red-50 border border-red-100 rounded-xl text-red-600 text-xs font-semibold text-center mb-4">
          <i class="fas fa-exclamation-circle mr-1"></i> {{error}}
        </div>
        {{/if}}
      </div>

      <!-- Login Form -->
      <form action="/login" method="POST" class="space-y-6" id="login-form">
        <div>
          <label class="block text-[10px] font-black uppercase tracking-widest text-dark/60 mb-2">Client ID</label>
          <input type="text" name="clientId" id="clientId" placeholder="Enter your Client ID" required 
            class="w-full px-5 py-4 rounded-xl border border-black/10 bg-cream text-dark font-medium text-sm focus:outline-none focus:border-primary transition-colors">
        </div>

        <div>
          <label class="block text-[10px] font-black uppercase tracking-widest text-dark/60 mb-2">Password</label>
          <input type="password" name="password" id="password" placeholder="••••••••" required 
            class="w-full px-5 py-4 rounded-xl border border-black/10 bg-cream text-dark font-medium text-sm focus:outline-none focus:border-primary transition-colors">
        </div>

        <button type="submit" class="w-full bg-primary text-white py-4.5 rounded-xl font-bold uppercase tracking-widest text-xs shadow-lg shadow-primary/30 hover:bg-green-600 hover:-translate-y-0.5 transition duration-300 magnetic-btn flex items-center justify-center gap-2">
          Sign In <i class="fas fa-sign-in-alt"></i>
        </button>
      </form>

      <div class="relative my-8 text-center">
        <hr class="border-black/5">
        <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white/80 px-4 text-[9px] font-black uppercase tracking-widest text-dark/30">Or Try Demo</span>
      </div>

      <!-- Demo Sign In -->
      <button onclick="loginAsDemo()" class="w-full bg-dark text-white py-4.5 rounded-xl font-black uppercase tracking-widest text-xs shadow-lg hover:bg-primary transition duration-300 magnetic-btn flex items-center justify-center gap-2">
        Demo Client Account <i class="fas fa-arrow-right"></i>
      </button>

      <p class="text-[10px] text-center text-dark/40 font-medium mt-6">
        *Demo credentials: client ID: <code>demo</code> / password: <code>demo</code>
      </p>

    </div>
  </div>
</section>

<script>
  function loginAsDemo() {
    document.getElementById('clientId').value = 'demo';
    document.getElementById('password').value = 'demo';
    setTimeout(() => {
      document.getElementById('login-form').submit();
    }, 100);
  }
</script>
