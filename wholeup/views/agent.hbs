<!-- CSS adjustments -->
<style>
  #terminal-feed::-webkit-scrollbar { width:4px; }
  #terminal-feed::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.1); border-radius:4px; }
</style>

<!-- Terminal and Gate script -->
<script>
  let activeProposalText = '';
  let activeContentText = '';

  function logToTerminal(text, type = 'info') {
    const feed = document.getElementById('terminal-feed');
    if (!feed) return;
    const div = document.createElement('div');
    const timestamp = new Date().toLocaleTimeString();
    
    let color = 'text-slate-300';
    if (type === 'success') color = 'text-green-400 font-bold';
    if (type === 'warning') color = 'text-yellow-400 font-bold';
    if (type === 'error') color = 'text-red-400 font-bold';
    if (type === 'agent') color = 'text-green-500 font-bold';

    div.className = `${color}`;
    div.innerHTML = `[${timestamp}] ${text}`;
    feed.appendChild(div);
    feed.scrollTop = feed.scrollHeight;
  }

  async function triggerOutreachAgent(index, name, service, email) {
    const terminal = document.getElementById('terminal-feed');
    const proposalCard = document.getElementById('proposal-preview-card');
    if (proposalCard) proposalCard.classList.add('hidden');
    
    logToTerminal(`🚀 TRIGGERED: Outreach Agent initialized for lead #${index} (${name})...`, 'agent');
    
    setTimeout(() => {
      logToTerminal(`Agent: Inspecting target service profile: [${service}]...`, 'info');
    }, 800);

    setTimeout(() => {
      logToTerminal(`Agent: Incorporating settings: "${document.getElementById('system-prompt-tuner').value.substring(0, 40)}..."`, 'info');
    }, 1800);

    setTimeout(() => {
      logToTerminal(`Agent: Invoking Google Gemini AI Agent with sales outreaching prompt...`, 'info');
    }, 2800);

    setTimeout(async () => {
      try {
        const response = await fetch('/api/agent/outreach', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ index: index })
        });
        
        const data = await response.json();
        
        if (data.success) {
          logToTerminal(`Agent: Gemini AI generated custom professional proposal successfully!`, 'success');
          
          if (data.emailSent) {
            logToTerminal(`✉️ Agent: Dispatched proposal email automatically to ${email || 'Client'}!`, 'success');
            logToTerminal(`Agent: Outreach cycle completed successfully! ✅`, 'agent');
          } else {
            logToTerminal(`⚠️ Agent: SMTP credentials not set in .env. Email dispatch skipped.`, 'warning');
            logToTerminal(`Agent: Outreach draft compiled and loaded to preview dashboard!`, 'success');
          }

          if (proposalCard) {
            activeProposalText = data.proposal;
            const output = document.getElementById('proposal-output');
            if (output) output.innerText = data.proposal;
            proposalCard.classList.remove('hidden');
          }
          
        } else {
          logToTerminal(`❌ ERROR: AI Agent failed to compile outreach. Reason: ${data.message}`, 'error');
        }
      } catch (err) {
        logToTerminal(`❌ ERROR: Connection failed. ${err.message}`, 'error');
      }
    }, 3800);
  }

  async function generateSocialContent() {
    const topicInput = document.getElementById('copilot-topic');
    if (!topicInput) return;
    const topic = topicInput.value.trim();
    if (!topic) return alert('Kripya koi topic enter karein!');
    
    const resultBox = document.getElementById('content-studio-result');
    if (resultBox) resultBox.classList.add('hidden');
    
    logToTerminal(`🚀 TRIGGERED: Content Copilot Agent initialized for topic: "${topic}"...`, 'agent');
    logToTerminal(`Agent: Analyzing market trends & dynamic hashtags for digital marketing...`, 'info');
    
    setTimeout(() => {
      logToTerminal(`Agent: Calling Gemini AI to write premium, high-converting social media outlines...`, 'info');
    }, 1200);

    try {
      const response = await fetch('/api/agent/content', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ topic: topic })
      });
      
      const data = await response.json();
      
      if (data.success) {
        logToTerminal(`Agent: Social media content generated successfully! Loading copy...`, 'success');
        
        activeContentText = data.content;
        const output = document.getElementById('copilot-output');
        if (output) output.innerText = data.content;
        if (resultBox) resultBox.classList.remove('hidden');
        topicInput.value = '';
      } else {
        logToTerminal(`❌ ERROR: Failed to generate content. Reason: ${data.message}`, 'error');
      }
    } catch(err) {
      logToTerminal(`❌ ERROR: Connection failed. ${err.message}`, 'error');
    }
  }

  function copyProposalText() {
    navigator.clipboard.writeText(activeProposalText);
    alert('Proposal draft successfully copied to clipboard!');
  }

  // --- Secure Gateway Check Logic (Adblocker-free implementation) ---
  const CORRECT_PASS = '1234';

  function getAccessSession() {
    try {
      return localStorage.getItem('wu_session');
    } catch (e) {
      console.warn('Local storage disabled:', e);
      return null;
    }
  }

  function setAccessSession(value) {
    try {
      localStorage.setItem('wu_session', value);
    } catch (e) {
      console.warn('Storage write disabled:', e);
    }
  }

  function clearAccessSession() {
    try {
      localStorage.removeItem('wu_session');
    } catch (e) {
      console.warn('Storage clear failed:', e);
    }
  }

  function checkAccess() {
    const isAuth = getAccessSession();
    const gateway = document.getElementById('user-gateway');
    const dashboard = document.getElementById('dashboard-view');
    
    if (!gateway || !dashboard) {
      console.error('Core gateway elements missing.');
      return;
    }

    if (isAuth === 'true') {
      gateway.style.opacity = '0';
      setTimeout(() => {
        gateway.style.display = 'none';
      }, 500);
      dashboard.classList.remove('hidden');
      dashboard.style.opacity = '1';
      
      // GSAP animate in
      if (typeof gsap !== 'undefined') {
        gsap.fromTo(dashboard, { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' });
      }
    } else {
      gateway.style.display = 'flex';
      gateway.style.opacity = '1';
      dashboard.classList.add('hidden');
      const passField = document.getElementById('entry-pass');
      if (passField) {
        setTimeout(() => passField.focus(), 50);
      }
    }
  }

  function verifyAccess() {
    const input = document.getElementById('entry-pass');
    const errorMsg = document.getElementById('entry-error');
    const lockIcon = document.getElementById('gate-icon');
    const gateway = document.getElementById('user-gateway');

    if (!input || !errorMsg || !lockIcon || !gateway) return;

    const code = input.value.trim();

    if (code === CORRECT_PASS) {
      errorMsg.classList.add('hidden');
      setAccessSession('true');
      
      // Succesful Unlock animation
      lockIcon.className = 'fas fa-shield-halved text-green-500';
      if (typeof gsap !== 'undefined') {
        gsap.to(lockIcon, { scale: 1.3, duration: 0.3, yoyo: true, repeat: 1 });
      }
      
      setTimeout(() => {
        checkAccess();
      }, 600);
    } else {
      input.value = '';
      errorMsg.classList.remove('hidden');
      lockIcon.className = 'fas fa-shield-halved text-red-500';
      
      // Shake animation
      const card = gateway.querySelector('div > div');
      if (card && typeof gsap !== 'undefined') {
        gsap.fromTo(card, 
          { x: -10 }, 
          { x: 10, duration: 0.08, repeat: 5, yoyo: true, onComplete: () => {
            gsap.set(card, { x: 0 });
            lockIcon.className = 'fas fa-shield-halved';
          }}
        );
      } else {
        lockIcon.className = 'fas fa-shield-halved';
      }
    }
  }

  function handlePinKeyPress(e) {
    if (e.key === 'Enter') {
      verifyAccess();
    }
  }

  function logoutGateway() {
    clearAccessSession();
    const input = document.getElementById('entry-pass');
    if (input) input.value = '';
    
    const gateway = document.getElementById('user-gateway');
    const dashboard = document.getElementById('dashboard-view');
    
    if (!gateway || !dashboard) return;

    if (typeof gsap !== 'undefined') {
      gsap.to(dashboard, {
        opacity: 0,
        y: 10,
        duration: 0.3,
        onComplete: () => {
          gateway.style.display = 'flex';
          gsap.to(gateway, { opacity: 1, duration: 0.3 });
          dashboard.classList.add('hidden');
          const passField = document.getElementById('entry-pass');
          if (passField) setTimeout(() => passField.focus(), 50);
        }
      });
    } else {
      gateway.style.display = 'flex';
      gateway.style.opacity = '1';
      dashboard.classList.add('hidden');
      const passField = document.getElementById('entry-pass');
      if (passField) setTimeout(() => passField.focus(), 50);
    }
  }

  // Load check access
  if (document.readyState === 'loading') {
    window.addEventListener('DOMContentLoaded', checkAccess);
  } else {
    checkAccess();
  }
</script>
