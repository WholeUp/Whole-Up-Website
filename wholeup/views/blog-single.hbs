<!-- HERO -->
<section class="page-hero bg-cream px-6 border-b border-black/5">
  <div class="max-w-4xl mx-auto gs-reveal">
    <a href="/blog" class="inline-flex items-center gap-2 text-sm font-bold text-dark/50 hover:text-dark mb-8 transition"><i class="fas fa-arrow-left"></i> Back to Blog</a>
    <div class="flex items-center gap-3 mb-6">
      <span class="text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full text-white" style="background:{{post.categoryColor}}">{{post.category}}</span>
      <span class="text-xs text-dark/40 font-medium">{{post.date}}</span>
      <span class="w-1 h-1 rounded-full bg-dark/20"></span>
      <span class="text-xs text-dark/40 font-medium">{{post.readTime}}</span>
    </div>
    <h1 class="text-4xl md:text-5xl font-black text-dark leading-tight mb-6">{{post.title}}</h1>
    <p class="text-dark/60 text-xl font-medium leading-relaxed">{{post.excerpt}}</p>
  </div>
</section>

<!-- CONTENT -->
<section class="py-24 bg-white px-6">
  <div class="max-w-4xl mx-auto grid md:grid-cols-3 gap-16">
    <div class="md:col-span-2">
      <div class="prose max-w-none text-dark/80 leading-relaxed" style="font-family:'Inter',sans-serif;font-size:1.05rem;line-height:1.8;">
        {{{post.content}}}
      </div>

      <!-- Share -->
      <div class="mt-16 pt-8 border-t border-black/5">
        <p class="text-xs font-bold uppercase tracking-widest text-dark/40 mb-4">Share this article</p>
        <div class="flex gap-4">
          <a href="https://twitter.com/intent/tweet?text={{post.title}}&url=https://wholeup.in/blog/{{post.slug}}" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-full bg-dark text-white flex items-center justify-center hover:bg-primary transition"><i class="fab fa-twitter text-sm"></i></a>
          <a href="https://www.linkedin.com/sharing/share-offsite/?url=https://wholeup.in/blog/{{post.slug}}" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-full bg-dark text-white flex items-center justify-center hover:bg-primary transition"><i class="fab fa-linkedin-in text-sm"></i></a>
          <a href="https://wa.me/?text={{post.title}}%20-%20https://wholeup.in/blog/{{post.slug}}" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-full bg-dark text-white flex items-center justify-center hover:bg-primary transition"><i class="fab fa-whatsapp text-sm"></i></a>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div>
      <!-- CTA Card -->
      <div class="bg-dark rounded-3xl p-8 text-white sticky top-32 gs-reveal">
        <p class="text-xs font-bold uppercase tracking-widest text-primary mb-4">Free Audit</p>
        <h3 class="text-xl font-black uppercase tracking-widest mb-4">Want These Results for Your Business?</h3>
        <p class="text-white/60 text-sm font-medium mb-8 leading-relaxed">We'll audit your digital presence for free and show you exactly where you're losing growth.</p>
        <a href="/contact" class="block bg-primary text-white text-center py-4 rounded-xl font-bold uppercase tracking-widest text-sm hover:bg-green-500 transition mb-4 magnetic-btn">Book Free Call</a>
        <a href="/services" class="block border border-white/20 text-white text-center py-4 rounded-xl font-bold uppercase tracking-widest text-sm hover:bg-white/10 transition magnetic-btn">Our Services</a>
      </div>
    </div>
  </div>
</section>

<!-- Related Posts -->
{{#if related}}
<section class="py-24 bg-cream px-6 border-t border-black/5">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl font-black uppercase tracking-widest text-dark mb-12 gs-reveal">More Articles</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {{#each related}}
      <a href="/blog/{{slug}}" class="bg-white rounded-[28px] overflow-hidden border border-black/5 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 gs-reveal block">
        <div class="h-40 flex items-center justify-center bg-gradient-to-br from-green-50 to-emerald-100">
          <i class="fas fa-pen-nib text-4xl text-primary/30"></i>
        </div>
        <div class="p-7">
          <span class="text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-full text-white mb-4 inline-block" style="background:{{categoryColor}}">{{category}}</span>
          <h3 class="text-lg font-black text-dark leading-tight mb-2 hover:text-primary transition">{{title}}</h3>
          <p class="text-dark/60 text-sm font-medium">{{readTime}}</p>
        </div>
      </a>
      {{/each}}
    </div>
  </div>
</section>
{{/if}}

<style>
  .prose h2 { font-size:1.7rem; font-weight:900; text-transform:uppercase; letter-spacing:.05em; color:#111; margin:2.5rem 0 1rem; }
  .prose h3 { font-size:1.2rem; font-weight:800; color:#111; margin:2rem 0 .75rem; }
  .prose p { margin-bottom:1.25rem; color:rgba(17,17,17,.7); }
  .prose a { color: #16A34A; text-decoration: underline; font-weight: 700; transition: color 0.2s ease; }
  .prose a:hover { color: #15803d; }
</style>

