<script>
  // Ultra smooth scroll
  let lenis;
  try {
    if (typeof Lenis !== 'undefined') {
      lenis = new Lenis({
        duration: 1.6,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smooth: true,
        smoothTouch: false,
        touchMultiplier: 1.5,
        infinite: false
      });
      function raf(time){ lenis.raf(time); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);

      // Progress bar
      const pBar = document.getElementById('progress-bar');
      if (pBar) {
        lenis.on('scroll', ({progress}) => {
          pBar.style.width = (progress*100) + '%';
        });
      }
    }
  } catch (e) {
    console.warn('Lenis failed to initialize:', e);
  }

  // Cursor
  const dot = document.querySelector('.cursor-dot');
  const shadow = document.querySelector('.cursor-shadow');
  if(dot && shadow) {
    let mx=0,my=0,sx=0,sy=0;
    document.addEventListener('mousemove',e=>{ mx=e.clientX; my=e.clientY; });
    function animateCursor(){
      sx+=(mx-sx)*.12; sy+=(my-sy)*.12;
      dot.style.left=mx+'px'; dot.style.top=my+'px';
      shadow.style.left=sx+'px'; shadow.style.top=sy+'px';
      requestAnimationFrame(animateCursor);
    }
    animateCursor();
    
    // Add Click ripple effect
    document.addEventListener('mousedown', () => {
      shadow.classList.add('cursor-click');
    });
    document.addEventListener('mouseup', () => {
      setTimeout(() => shadow.classList.remove('cursor-click'), 150);
    });
    document.querySelectorAll('a,button,.magnetic-btn').forEach(el=>{
      el.addEventListener('mouseenter',()=>document.body.classList.add('cursor-hover'));
      el.addEventListener('mouseleave',()=>{
        document.body.classList.remove('cursor-hover');
        if (typeof gsap !== 'undefined') {
          gsap.to(el,{x:0,y:0,duration:.5});
        }
      });
      el.addEventListener('mousemove',e=>{
        const r=el.getBoundingClientRect();
        if (typeof gsap !== 'undefined') {
          gsap.to(el,{x:(e.clientX-r.left-r.width/2)*.2,y:(e.clientY-r.top-r.height/2)*.2,duration:.3});
        }
      });
    });
  }

  // GSAP ScrollTrigger — ultra smooth staggered reveals
  try {
    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);
      if (lenis) {
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add(time=>lenis.raf(time*1000));
      }
      gsap.ticker.lagSmoothing(0);

      // Staggered reveal for groups
      gsap.utils.toArray('.gs-reveal').forEach((el, i) => {
        gsap.fromTo(el,
          { y: 32, opacity: 0, scale: 0.98 },
          { y: 0, opacity: 1, scale: 1, duration: 0.9, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 88%', once: true }
          }
        );
      });

      // Staggered cascade reveal for grids
      gsap.utils.toArray('.gs-stagger-parent').forEach((parent) => {
        const children = parent.querySelectorAll('.gs-stagger-item');
        gsap.fromTo(children,
          { y: 45, opacity: 0, scale: 0.96 },
          { 
            y: 0, 
            opacity: 1, 
            scale: 1, 
            duration: 0.85, 
            stagger: 0.08,
            ease: 'power3.out',
            scrollTrigger: { trigger: parent, start: 'top 85%', once: true }
          }
        );
      });
    } else {
      // Fallback: make all reveals visible immediately
      document.querySelectorAll('.gs-reveal, .gs-stagger-item').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }
  } catch (e) {
    console.warn('GSAP/ScrollTrigger initialization failed:', e);
    // Fallback: make all reveals visible immediately
    document.querySelectorAll('.gs-reveal, .gs-stagger-item').forEach(el => {
      el.style.opacity = '1';
      el.style.transform = 'none';
    });
  }

  // Enhanced VanillaTilt
  try {
    if(window.innerWidth>=768 && typeof VanillaTilt !== 'undefined'){
      VanillaTilt.init(document.querySelectorAll('[data-tilt]'),{
        glare:true,'max-glare':.04,scale:1.025,speed:400,perspective:1200
      });
    }
  } catch (e) {
    console.warn('VanillaTilt failed to initialize:', e);
  }

  // Mobile nav
  function toggleMobileMenu(){
    document.getElementById('mobile-menu').classList.toggle('open');
    document.getElementById('hamburger-btn').classList.toggle('active');
  }

  // Navbar scroll shadow
  window.addEventListener('scroll',()=>{
    const nav = document.getElementById('navbar');
    if(window.scrollY>50) nav.style.boxShadow='0 4px 30px rgba(0,0,0,.08)';
    else nav.style.boxShadow='none';
  });

  // Chatbot - Dynamic Gemini API with History & Interactive CTAs
  let dmOpen = false;
  let dmHistory = []; // Local array to persist conversation turns
  let dmContext = 'default';
  let wizardStep = 0;
  let wizardData = { goal: '', website: '', budget: '' };

  const chipData = {
    'default': [
      { text: "📱 Social Media / SMM", action: () => openChatbotWithContext("social") },
      { text: "💰 Paid Ads (PPC)", action: () => openChatbotWithContext("ppc") },
      { text: "🔍 Free SEO Check", action: () => openChatbotWithContext("seo") },
      { text: "💻 Need a Website", action: () => openChatbotWithContext("webdev") },
      { text: "💡 Find My Service", action: () => openChatbotWithContext("consultant") }
    ],
    'seo': [
      { text: "🔍 Audit My Website", action: () => dmAsk("Can you perform a free technical SEO audit of my website?") },
      { text: "📍 Local SEO / GMB", action: () => dmAsk("How can we attract local customers using Google Maps and Local SEO?") },
      { text: "📈 Rank on Page 1", action: () => dmAsk("Dominate Google search results on Page 1 by targeting buyer-intent keywords.") },
      { text: "🔙 Main Menu", action: () => openChatbotWithContext("default") }
    ],
    'ppc': [
      { text: "💰 Maximize ROAS", action: () => dmAsk("How can we double our Return on Ad Spend (ROAS) with paid ads?") },
      { text: "📱 Meta/Instagram Ads", action: () => dmAsk("What is the setup process and pricing details for Instagram and Facebook Ads?") },
      { text: "🎯 Lead Gen Campaigns", action: () => dmAsk("How do we set up Google Ads and a landing page funnel for lead generation?") },
      { text: "🔙 Main Menu", action: () => openChatbotWithContext("default") }
    ],
    'social': [
      { text: "🎬 Reels Viral Hooks", action: () => dmAsk("Can you share high-retention hooks and script ideas for short-form Reels?") },
      { text: "📈 Instagram Growth", action: () => dmAsk("How can we implement a strategy to grow followers and boost social engagement?") },
      { text: "📅 Content Strategy", action: () => dmAsk("What are the details and monthly pricing for brand content calendars?") },
      { text: "🔙 Main Menu", action: () => openChatbotWithContext("default") }
    ],
    'webdev': [
      { text: "⚡ Speed Optimization", action: () => dmAsk("My website load time is slow. How can we improve performance and speed index?") },
      { text: "🎨 Premium UI/UX Design", action: () => dmAsk("Fast, responsive, modern glassmorphic theme conversion-focused landing page layout.") },
      { text: "🛒 Shopify eCommerce", action: () => dmAsk("E-commerce website build and Shopify setups setup pricing details.") },
      { text: "🔙 Main Menu", action: () => openChatbotWithContext("default") }
    ]
  };

  function dmToggle(){ dmOpen=!dmOpen; document.getElementById('dm-chat-box').style.display=dmOpen?'flex':'none'; document.getElementById('dm-badge').style.display='none'; if(dmOpen) document.getElementById('dm-input').focus(); }
  function dmAsk(t){ document.getElementById('dm-input').value=t; dmSend(); }

  async function dmSend(){
    const input=document.getElementById('dm-input');
    const text=input.value.trim(); if(!text) return; input.value='';
    const msgs=document.getElementById('dm-messages');
    
    // Add user message to UI
    const uDiv=document.createElement('div');
    uDiv.className='dm-msg user';
    uDiv.innerHTML=`<div class="dm-av user">Ap</div><div class="dm-bubble user">${escapeHtml(text)}</div>`;
    msgs.appendChild(uDiv);
    msgs.scrollTop=msgs.scrollHeight;
    
    await dmSendText(text);
  }

  async function dmSendText(text) {
    const msgs=document.getElementById('dm-messages');
    
    // Add typing indicator
    const typDiv=document.createElement('div');
    typDiv.className='dm-msg';
    typDiv.id='dm-typ';
    typDiv.innerHTML=`<div class="dm-av bot">AI</div><div class="dm-bubble bot"><div class="dm-typing"><span></span><span></span><span></span></div></div>`;
    msgs.appendChild(typDiv);
    msgs.scrollTop=msgs.scrollHeight;
    
    const userMsg = { role: 'user', parts: [{ text: text }] };
    
    try {
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, history: dmHistory, context: dmContext })
      });
      
      const data = await response.json();
      
      // Remove typing indicator
      const t = document.getElementById('dm-typ');
      if (t) t.remove();
      
      const reply = data.success ? data.reply : 'We apologize, but our servers are temporarily offline. Please contact us directly at +91 94268 46035.';
      
      // Update local conversational memory history state
      if (data.success) {
        dmHistory.push(userMsg);
        dmHistory.push({ role: 'model', parts: [{ text: reply }] });
        
        // Cap history to keep payload size reasonable
        if (dmHistory.length > 20) {
          dmHistory = dmHistory.slice(dmHistory.length - 20);
        }
      }
      
      // Add bot response to UI
      const aDiv=document.createElement('div');
      aDiv.className='dm-msg';
      aDiv.innerHTML=`<div class="dm-av bot">AI</div><div class="dm-bubble bot">${formatReply(reply)}</div>`;
      msgs.appendChild(aDiv);
      msgs.scrollTop=msgs.scrollHeight;

      // If we completed consultant wizard, go back to default context and load default chips
      if (dmContext === 'consultant') {
        dmContext = 'default';
      }
      loadSuggestionChips(dmContext);
    } catch(err) {
      console.error(err);
      const t = document.getElementById('dm-typ');
      if (t) t.remove();
      const aDiv=document.createElement('div');
      aDiv.className='dm-msg';
      aDiv.innerHTML=`<div class="dm-av bot">AI</div><div class="dm-bubble bot">It seems there is a network connectivity issue. Please call us directly at +91 94268 46035.</div>`;
      msgs.appendChild(aDiv);
      msgs.scrollTop=msgs.scrollHeight;
    }
  }

  function loadSuggestionChips(contextVal) {
    const container = document.getElementById('dm-chips-container');
    if (!container) return;
    container.innerHTML = '';
    
    let ctxKey = contextVal || 'default';
    if (ctxKey === 'web') ctxKey = 'webdev';
    if (ctxKey === 'ads') ctxKey = 'ppc';
    if (ctxKey === 'smm') ctxKey = 'social';
    
    const chips = chipData[ctxKey] || chipData['default'];
    
    chips.forEach(chip => {
      const btn = document.createElement('button');
      btn.className = 'dm-chip';
      btn.innerText = chip.text;
      btn.onclick = chip.action;
      container.appendChild(btn);
    });
  }

  function openChatbotWithContext(slugOrContext) {
    let contextVal = 'default';
    if (slugOrContext === 'local-seo' || slugOrContext === 'seo' || slugOrContext === 'content-writing') {
      contextVal = 'seo';
    } else if (slugOrContext === 'meta-ads' || slugOrContext === 'ppc-google-ads' || slugOrContext === 'whatsapp-marketing' || slugOrContext === 'ecommerce-marketing' || slugOrContext === 'amazon-marketing') {
      contextVal = 'ppc';
    } else if (slugOrContext === 'reel-shoot-edit' || slugOrContext === 'linkedin-marketing' || slugOrContext === 'social-media-management') {
      contextVal = 'social';
    } else if (slugOrContext === 'website-designing' || slugOrContext === 'graphic-designing' || slugOrContext === 'generative-ai-video' || slugOrContext === 'automation') {
      contextVal = 'webdev';
    } else if (slugOrContext === 'consultant') {
      contextVal = 'consultant';
    } else {
      contextVal = slugOrContext;
    }

    dmContext = contextVal;
    
    // Open chatbox
    dmOpen = true;
    document.getElementById('dm-chat-box').style.display = 'flex';
    document.getElementById('dm-badge').style.display = 'none';
    
    const msgs = document.getElementById('dm-messages');
    
    // Clear chips container first
    const container = document.getElementById('dm-chips-container');
    if (container) container.innerHTML = '';

    if (contextVal === 'consultant') {
      wizardStep = 1;
      wizardData = { goal: '', website: '', budget: '' };
      dmHistory = [];
      
      const aDiv = document.createElement('div');
      aDiv.className = 'dm-msg';
      aDiv.innerHTML = `
        <div class="dm-av bot">AI</div>
        <div class="dm-bubble bot">
          <strong>Wholeup Consultant Wizard 🚀</strong><br><br>
          Hello! I will help suggest the right digital marketing service package for your business.<br><br>
          First, please tell us: <strong>What is your main business goal?</strong>
        </div>
      `;
      msgs.appendChild(aDiv);
      msgs.scrollTop = msgs.scrollHeight;
      
      renderConsultantChips();
    } else {
      let greeting = '';
      if (contextVal === 'seo') {
        greeting = "Hello! 👋 I am Wholeup's <strong>SEO Specialist</strong> assistant. How can I help you with Google search rankings and organic business growth?";
      } else if (contextVal === 'ppc') {
        greeting = "Hello! 👋 I am Wholeup's <strong>Paid Ads Strategist</strong> assistant. What would you like to know about scaling Meta, Google, and WhatsApp marketing campaigns?";
      } else if (contextVal === 'social') {
        greeting = "Hello! 👋 I am Wholeup's <strong>Social Media Growth Expert</strong> assistant. Do you have questions about Reels production, content strategy, or outbound B2B LinkedIn plans?";
      } else if (contextVal === 'webdev') {
        greeting = "Hello! 👋 I am Wholeup's <strong>Full-Stack Web Dev Expert</strong> assistant. Ask me about website speed, automation flows, graphic design, or modern conversion layouts.";
      } else {
        greeting = "Hello! 👋 I am Wholeup's <strong>GrowBot</strong> AI assistant.<br><br>I will partner with you to scale your business and reach your target customers. What would you like to scale today?";
      }
      
      const aDiv = document.createElement('div');
      aDiv.className = 'dm-msg';
      aDiv.innerHTML = `
        <div class="dm-av bot">AI</div>
        <div class="dm-bubble bot">${greeting}</div>
      `;
      msgs.appendChild(aDiv);
      msgs.scrollTop = msgs.scrollHeight;
      
      loadSuggestionChips(contextVal);
    }
    document.getElementById('dm-input').focus();
  }

  function renderConsultantChips() {
    const container = document.getElementById('dm-chips-container');
    if (!container) return;
    container.innerHTML = '';
    
    if (wizardStep === 1) {
      const options = [
        { text: "📈 Leads & Clients", value: "Grow Leads & Clients" },
        { text: "🛒 Sales Online", value: "Online Sales (E-commerce)" },
        { text: "📱 Brand Followers", value: "Brand Awareness & Followers" }
      ];
      options.forEach(opt => {
        const btn = document.createElement('button');
        btn.className = 'dm-chip';
        btn.innerText = opt.text;
        btn.onclick = () => selectWizardOption(opt.value);
        container.appendChild(btn);
      });
    } else if (wizardStep === 2) {
      const options = [
        { text: "🌐 Active Website", value: "I have an active website" },
        { text: "🆕 New Website", value: "I need a new website" },
        { text: "❌ Website Nahi", value: "I do not need a website" }
      ];
      options.forEach(opt => {
        const btn = document.createElement('button');
        btn.className = 'dm-chip';
        btn.innerText = opt.text;
        btn.onclick = () => selectWizardOption(opt.value);
        container.appendChild(btn);
      });
    } else if (wizardStep === 3) {
      const options = [
        { text: "💵 Under ₹15,000", value: "Under ₹15,000" },
        { text: "💵 ₹15k - ₹40k", value: "₹15,000 - ₹40,000" },
        { text: "💵 ₹40k+", value: "₹40,000+" }
      ];
      options.forEach(opt => {
        const btn = document.createElement('button');
        btn.className = 'dm-chip';
        btn.innerText = opt.text;
        btn.onclick = () => selectWizardOption(opt.value);
        container.appendChild(btn);
      });
    }
  }

  function selectWizardOption(value) {
    const msgs = document.getElementById('dm-messages');
    
    const uDiv = document.createElement('div');
    uDiv.className = 'dm-msg user';
    uDiv.innerHTML = `<div class="dm-av user">Ap</div><div class="dm-bubble user">${escapeHtml(value)}</div>`;
    msgs.appendChild(uDiv);
    msgs.scrollTop = msgs.scrollHeight;
    
    if (wizardStep === 1) {
      wizardData.goal = value;
      wizardStep = 2;
      setTimeout(() => {
        const aDiv = document.createElement('div');
        aDiv.className = 'dm-msg';
        aDiv.innerHTML = `
          <div class="dm-av bot">AI</div>
          <div class="dm-bubble bot">Great choice! 👍 Do you currently have an active website, or are you planning a new one?</div>
        `;
        msgs.appendChild(aDiv);
        msgs.scrollTop = msgs.scrollHeight;
        renderConsultantChips();
      }, 500);
    } else if (wizardStep === 2) {
      wizardData.website = value;
      wizardStep = 3;
      setTimeout(() => {
        const aDiv = document.createElement('div');
        aDiv.className = 'dm-msg';
        aDiv.innerHTML = `
          <div class="dm-av bot">AI</div>
          <div class="dm-bubble bot">Perfect. One last question: What is your monthly marketing budget range?</div>
        `;
        msgs.appendChild(aDiv);
        msgs.scrollTop = msgs.scrollHeight;
        renderConsultantChips();
      }, 500);
    } else if (wizardStep === 3) {
      wizardData.budget = value;
      wizardStep = 0;
      
      const query = `I need a marketing consultation. My Goal: ${wizardData.goal}, My Website Status: ${wizardData.website}, My Budget: ${wizardData.budget}. Please recommend the best marketing services and strategy packages for me.`;
      
      setTimeout(() => {
        const container = document.getElementById('dm-chips-container');
        if (container) container.innerHTML = '';
        dmSendText(query);
      }, 500);
    }
  }

  function escapeHtml(string) {
    return String(string).replace(/[&<>"'`=\/]/g, function (s) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;', '/': '&#x2F;', '=': '&#x3D;' }[s];
    });
  }

  function formatReply(text) {
    let html = escapeHtml(text);
    html = html.replace(/\n/g, '<br>');
    html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    html = html.replace(/(?:^|<br>)\s*[-*]\s(.*?)(?=<br>|$)/g, function(match, p1) {
      return '<br>• ' + p1;
    });
    
    html = html.replace(/\[CALL_CTA\]/g, `<a href="tel:+919426846035" class="inline-flex items-center gap-2 mt-3 px-4 py-2.5 bg-green-600 hover:bg-green-700 text-white font-semibold text-xs rounded-full shadow-lg shadow-green-600/25 hover:shadow-green-600/40 hover:-translate-y-0.5 active:translate-y-0 transition-all w-full justify-center cursor-pointer no-underline"><i class="fas fa-phone-alt animate-bounce"></i> Call +91 94268 46035 Now</a>`);
    html = html.replace(/\[WHATSAPP_CTA\]/g, `<a href="https://wa.me/919426846035" target="_blank" class="inline-flex items-center gap-2 mt-2 px-4 py-2.5 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold text-xs rounded-full shadow-lg shadow-emerald-500/25 hover:shadow-emerald-500/40 hover:-translate-y-0.5 active:translate-y-0 transition-all w-full justify-center cursor-pointer no-underline"><i class="fab fa-whatsapp text-sm"></i> Message on WhatsApp</a>`);
    html = html.replace(/(<br>){3,}/g, '<br><br>');
    return html;
  }

  // Initialize chips on DOMContentLoaded
  window.addEventListener('DOMContentLoaded', () => {
    loadSuggestionChips('default');
  });

  // Premium Branded Preloader Script (W Growth Animation - All Pages, Every Load)
  (function() {
    const preloader = document.getElementById('preloader');
    if (!preloader) return;
    
    // Prevent scrolling while preloader runs
    document.body.style.overflow = 'hidden';
    
    // Check and stop Lenis scroll dynamically
    if (typeof lenis !== 'undefined' && lenis) {
      lenis.stop();
    } else {
      const checkLenis = setInterval(() => {
        if (typeof lenis !== 'undefined' && lenis) {
          lenis.stop();
          clearInterval(checkLenis);
        }
      }, 50);
      setTimeout(() => clearInterval(checkLenis), 3000);
    }
    
    // Start drawing animation on DOM Content Loaded
    window.addEventListener('DOMContentLoaded', () => {
      if (typeof gsap === 'undefined') {
        setTimeout(finishLoading, 2200);
        return;
      }

      // Cross-browser safe initialization of scale and origin
      gsap.set('#loader-arrow-head', { scale: 0, transformOrigin: '50% 50%', opacity: 1 });
      gsap.set('#loader-star', { scale: 0, transformOrigin: '50% 50%', opacity: 1 });

      const tl = gsap.timeline({
        onComplete: () => {
          // Wait exactly 400ms after the W completes, then start the exit transition!
          setTimeout(startExit, 400);
        }
      });
      
      // 1. Draw Left Black Wing (starts immediately)
      tl.to('#loader-left-wing', {
        strokeDashoffset: 0,
        duration: 1.0,
        ease: 'power3.out'
      }, 0);
      
      // 2. Draw Right Green Wing (starts simultaneously at 0.0)
      tl.to('#loader-right-wing', {
        strokeDashoffset: 0,
        duration: 1.0,
        ease: 'power3.out'
      }, 0);
      
      // 3. Arrowhead Pop In, Scale Up & Bounce (starts at 0.8s, near the end of wing drawing)
      tl.to('#loader-arrow-head', {
        scale: 1,
        duration: 0.55,
        ease: 'back.out(1.7)'
      }, 0.8);

      // 4. Sparkle Star Pop In, Spin/Scale and Shine (starts at 0.9s, staggered)
      tl.to('#loader-star', {
        scale: 1,
        rotation: 45,
        duration: 0.55,
        ease: 'back.out(1.5)'
      }, 0.9);
    });

    function startExit() {
      if (typeof gsap !== 'undefined' && preloader) {
        const exitTl = gsap.timeline({
          onComplete: () => {
            preloader.style.display = 'none';
            document.body.style.overflow = '';
            if (typeof lenis !== 'undefined' && lenis) {
              lenis.start();
            }
            if (typeof ScrollTrigger !== 'undefined') {
              ScrollTrigger.refresh();
            }
          }
        });
        
        // Parallax logo exit (slides up slightly faster & fades out)
        exitTl.to('#loader-logo-wrap', {
          y: -100,
          opacity: 0,
          duration: 0.45,
          ease: 'power2.in'
        });
        
        // Premium curtain slide-up
        exitTl.to(preloader, {
          yPercent: -100,
          duration: 0.75,
          ease: 'power4.inOut'
        }, "-=0.3");

        // Premium parallax page reveal (fades and rises up dynamically)
        exitTl.fromTo('main', {
          y: 40,
          opacity: 0
        }, {
          y: 0,
          opacity: 1,
          duration: 0.75,
          ease: 'power3.out'
        }, "-=0.55");
      } else {
        finishLoading();
      }
    }

    function finishLoading() {
      if (preloader) {
        preloader.style.transition = 'transform 0.65s cubic-bezier(0.77, 0, 0.175, 1)';
        preloader.style.transform = 'translateY(-100%)';
        setTimeout(() => {
          preloader.style.display = 'none';
          document.body.style.overflow = '';
          if (typeof lenis !== 'undefined' && lenis) {
            lenis.start();
          }
        }, 700);
      }
    }
  })();
</script>
</body>
</html>
