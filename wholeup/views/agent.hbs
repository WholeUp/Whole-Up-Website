<!-- Secure Gate Container (Bypasses Adblockers by using generic naming) -->
<div id="user-gateway" class="fixed inset-0 backdrop-blur-2xl flex items-center justify-center p-6 transition-all duration-500" style="display: flex; opacity: 1; background: rgba(8, 10, 15, 0.98); z-index: 999999;">
  <div class="max-w-md w-full p-10 rounded-[32px] text-center relative overflow-hidden shadow-2xl" style="background: #0B0F19; border: 1px solid rgba(34, 197, 94, 0.15); box-shadow: 0 20px 50px rgba(0,0,0,0.5);">
    <div class="absolute -top-12 -right-12 w-32 h-32 bg-green-500/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-12 -left-12 w-32 h-32 bg-green-500/5 rounded-full blur-3xl"></div>
    
    <!-- Lock Shield Icon -->
    <div class="w-20 h-20 bg-green-500/10 border border-green-500/30 rounded-full flex items-center justify-center mx-auto mb-6 text-green-500 shadow-[0_0_20px_rgba(34,197,94,0.1)]">
      <i class="fas fa-shield-halved text-3xl animate-pulse" id="gate-icon"></i>
    </div>
    
    <h2 class="text-2xl font-black text-white uppercase tracking-widest mb-2 font-heading">Secure Autopilot Access</h2>
    <p class="text-gray-400 text-xs font-semibold uppercase tracking-wider mb-8">Enter access code to initialize controller</p>
    
    <div class="space-y-4">
      <div class="relative">
        <input type="password" id="entry-pass" maxlength="4" placeholder="••••" class="w-full bg-white/5 border border-white/10 rounded-2xl py-4.5 text-center text-3xl font-bold tracking-[0.5em] text-white focus:outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500 transition duration-300" style="background: rgba(255,255,255,0.02); font-family: sans-serif;" onkeypress="handlePinKeyPress(event)">
      </div>
      
      <div id="entry-error" class="text-red-400 text-xs font-bold uppercase tracking-wider hidden animate-pulse">
        <i class="fas fa-exclamation-triangle mr-1"></i> Access Denied: Invalid Code
      </div>
      
      <button onclick="verifyAccess()" class="w-full bg-green-600 hover:bg-green-500 text-white font-black uppercase tracking-widest text-xs py-4.5 rounded-2xl shadow-lg shadow-green-600/20 hover:shadow-green-600/40 transition-all duration-300 cursor-pointer mt-4 hover:-translate-y-0.5 active:translate-y-0">
        Verify Credentials
      </button>
    </div>
  </div>
</div>

