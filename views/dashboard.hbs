<!-- Audio Alert & Simulations scripts -->
<script>
  function simulateNewLead() {
    const table = document.getElementById('leads-log-table');
    const firstNames = ["Rajesh", "Neha", "Kunal", "Tanya", "Vikram", "Meera", "Deepak", "Anjali"];
    const lastNames = ["Mehta", "Sharma", "Kothari", "Goel", "Jain", "Bose", "Ahuja", "Kapoor"];
    const channels = [
      { name: "Meta Ads", bg: "bg-blue-50 text-blue-600" },
      { name: "Google Ads", bg: "bg-orange-50 text-orange-600" },
      { name: "SEO Organic", bg: "bg-green-50 text-primary" },
      { name: "WhatsApp Bot", bg: "bg-emerald-50 text-emerald-600" }
    ];
    const statuses = [
      { name: "Contacted", bg: "bg-green-50 text-green-600" },
      { name: "Nurturing", bg: "bg-purple-50 text-purple-600" },
      { name: "Awaiting Reply", bg: "bg-orange-100 text-orange-700" }
    ];

    const randomName = firstNames[Math.floor(Math.random() * firstNames.length)] + " " + lastNames[Math.floor(Math.random() * lastNames.length)];
    const randomPhone = "+91 " + (Math.floor(Math.random() * 90000) + 10000) + " XXXXX";
    const randomChannel = channels[Math.floor(Math.random() * channels.length)];
    const randomStatus = statuses[Math.floor(Math.random() * statuses.length)];

    // Create new lead row HTML
    const tr = document.createElement('tr');
    tr.className = "hover:bg-cream/40 transition-colors bg-green-50/20";
    tr.innerHTML = `
      <td class="py-4 font-black">${randomName}</td>
      <td class="py-4 font-mono">${randomPhone}</td>
      <td class="py-4"><span class="px-2.5 py-1 rounded-full ${randomChannel.bg} text-[10px] font-bold uppercase">${randomChannel.name}</span></td>
      <td class="py-4"><span class="px-2.5 py-1 rounded-full ${randomStatus.bg} text-[10px] font-bold uppercase">${randomStatus.name}</span></td>
      <td class="py-4 text-right text-dark/40 text-[10px] font-mono">Just Now</td>
    `;

    // Prepend row and fade in
    table.insertBefore(tr, table.firstChild);
    
    // Play alert bell sound using standard web synth audio
    playSystemBeep();

    // Stagger transition entry
    if (typeof gsap !== 'undefined') {
      gsap.from(tr, { opacity: 0, y: -20, duration: 0.5, ease: 'power2.out' });
      gsap.to(tr, { backgroundColor: 'transparent', delay: 1.5, duration: 1.0 });
    }
  }

  function playSystemBeep() {
    try {
      const context = new (window.AudioContext || window.webkitAudioContext)();
      const osc = context.createOscillator();
      const gain = context.createGain();
      
      osc.type = 'sine';
      osc.frequency.setValueAtTime(587.33, context.currentTime); // D5 note
      osc.frequency.setValueAtTime(880, context.currentTime + 0.08); // A5 note
      
      gain.gain.setValueAtTime(0.08, context.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, context.currentTime + 0.35);
      
      osc.connect(gain);
      gain.connect(context.destination);
      
      osc.start();
      osc.stop(context.currentTime + 0.35);
    } catch(e) {}
  }
</script>
