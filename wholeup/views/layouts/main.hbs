<body class="antialiased selection:bg-primary selection:text-white bg-grid">

<!-- Premium Branded Page Preloader -->
<div id="preloader" class="fixed inset-0 bg-[#FAF8F2] z-[9999999] flex flex-col items-center justify-center pointer-events-auto select-none overflow-hidden">
  <div class="z-10 flex flex-col items-center text-center px-6">
    <!-- Sleek Custom Animated W Growth Logo -->
    <div class="relative" id="loader-logo-wrap">
      <svg class="w-64 h-64 md:w-80 md:h-80" viewBox="0 0 1000 700" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- Shadow Filter for Overlap Depth -->
          <filter id="overlap-shadow" x="-30%" y="-30%" width="160%" height="160%">
            <feDropShadow dx="-12" dy="12" stdDeviation="16" flood-color="#0D0D0D" flood-opacity="0.35"/>
          </filter>

          <!-- Dark Charcoal Gradient for left wing with userSpaceOnUse -->
          <linearGradient id="charcoal-loader-grad" x1="180" y1="270" x2="465" y2="590" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#2D2D2D" />
            <stop offset="100%" stop-color="#121212" />
          </linearGradient>
          
          <!-- Bright Green Gradient for right wing and arrowhead with userSpaceOnUse -->
          <linearGradient id="green-loader-grad" x1="465" y1="590" x2="900" y2="100" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#1E521F" />
            <stop offset="60%" stop-color="#4EAB30" />
            <stop offset="100%" stop-color="#55C235" />
          </linearGradient>
        </defs>

        <!-- Right Green Wing (Rendered first so it is in the background) -->
        <path d="M 465 380 C 455 420, 500 590, 570 590 C 640 590, 710 350, 790 210" 
              stroke="url(#green-loader-grad)" 
              stroke-width="105" 
              stroke-linecap="butt" 
              stroke-linejoin="round" 
              id="loader-right-wing" 
              style="stroke-dasharray: 1000; stroke-dashoffset: 1000;" />

        <!-- Left Black Wing (Rendered on top of green wing, with shadow filter) -->
        <path d="M 180 270 C 180 270, 260 590, 330 590 C 400 590, 440 480, 465 380" 
              stroke="url(#charcoal-loader-grad)" 
              stroke-width="105" 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              filter="url(#overlap-shadow)"
              id="loader-left-wing" 
              style="stroke-dasharray: 1000; stroke-dashoffset: 1000;" />

        <!-- Solid Arrow Head (Polygon matching the image ditto to ditto) -->
        <polygon points="712,165 850,106 868,255 790,210" 
                 fill="url(#green-loader-grad)"
                 id="loader-arrow-head" 
                 style="opacity: 0;" />

        <!-- Single Sparkle Star (Top Right) -->
        <path d="M 880 25 Q 880 60 915 60 Q 880 60 880 95 Q 880 60 845 60 Q 880 60 880 25" 
              fill="#55C235" 
              id="loader-star" 
              style="opacity: 0;" />
      </svg>
    </div>
  </div>
</div>

<div id="debug-error-panel" style="display: none; background: #fee2e2; color: #991b1b; border: 2px solid #f87171; padding: 20px; font-family: monospace; font-size: 14px; position: fixed; top: 80px; left: 20px; right: 20px; z-index: 9999999; border-radius: 12px; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); max-height: 400px; overflow-y: auto;">
  <h3 style="margin-top: 0; font-weight: bold; font-size: 16px;">⚠️ Client-Side JS Error Detected:</h3>
  <pre id="debug-error-log" style="white-space: pre-wrap; margin: 0;"></pre>
  <button onclick="document.getElementById('debug-error-panel').style.display='none'" style="margin-top: 12px; background: #ef4444; color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-weight: bold;">Close Panel</button>
</div>
<script>
  window.addEventListener('error', function(event) {
    const panel = document.getElementById('debug-error-panel');
    const log = document.getElementById('debug-error-log');
    if (panel && log) {
      panel.style.display = 'block';
      log.textContent += event.message + '\n  at ' + event.filename + ':' + event.lineno + ':' + event.colno + '\n\n';
    }
  });
  window.addEventListener('unhandledrejection', function(event) {
    const panel = document.getElementById('debug-error-panel');
    const log = document.getElementById('debug-error-log');
    if (panel && log) {
      panel.style.display = 'block';
      log.textContent += 'Unhandled Promise Rejection: ' + event.reason + '\n\n';
    }
  });
</script>

