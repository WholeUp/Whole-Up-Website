<style>
  @keyframes loadingProgress {
    0% { width: 0%; }
    30% { width: 45%; }
    70% { width: 85%; }
    100% { width: 100%; }
  }
</style>

<script>
  // Pre-fill parameters if redirected from ROI calculator
  window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    if (params.has('spend')) {
      const spend = params.get('spend');
      const roas = params.get('roas');
      const cpl = params.get('cpl');
      const msgArea = document.querySelector('textarea[name="message"]');
      if (msgArea) {
        msgArea.value = `I calculated my ROI using the calculator. My parameters: Monthly Ad Spend: ₹${parseInt(spend).toLocaleString('en-IN')}, Target ROAS: ${roas}x, Average CPL: ₹${cpl}. I'd like a custom marketing strategy based on these details.`;
      }
    }
  });

  const statuses = [
    'Scanning website meta tags...',
    'Performing speed & core web vitals check...',
    'Analyzing visual hierarchy & CTA gaps...',
    'Running competitor ranking analysis...',
    'AI Agent compiling marketing roadmap report...'
  ];

  let statusInterval;

  function runStatusRotator() {
    const statusText = document.getElementById('loading-status');
    let idx = 0;
    statusInterval = setInterval(() => {
      idx = (idx + 1) % statuses.length;
      statusText.textContent = statuses[idx];
    }, 1500);
  }

  function resetGrader() {
    document.getElementById('grader-report').classList.add('hidden');
    document.getElementById('contact-form').classList.remove('hidden');
    document.getElementById('grader-header').classList.remove('hidden');
    document.getElementById('contact-form').reset();
  }

  document.getElementById('contact-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = this;
    const loader = document.getElementById('grader-loading');
    const errBox = document.getElementById('form-error');

    loader.classList.remove('hidden');
    errBox.classList.add('hidden');
    runStatusRotator();

    const formData = new FormData(this);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/api/grader/audit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const result = await res.json();
      
      clearInterval(statusInterval);
      loader.classList.add('hidden');

      if (result.success) {
        // Inject values and render report screen
        form.classList.add('hidden');
        document.getElementById('grader-header').classList.add('hidden');
        document.getElementById('report-domain').innerText = data.url;
        document.getElementById('report-goal').innerText = data.goal;
        document.getElementById('report-content').innerText = result.audit;
        document.getElementById('grader-report').classList.remove('hidden');
      } else {
        errBox.textContent = result.message || 'Grader failed to generate audit. Please try again.';
        errBox.classList.remove('hidden');
      }
    } catch(err) {
      clearInterval(statusInterval);
      loader.classList.add('hidden');
      errBox.textContent = 'Connection error. Please try again or call us directly.';
      errBox.classList.remove('hidden');
    }
  });
</script>
